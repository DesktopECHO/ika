#!/usr/bin/env bash

# Build Mesa packages from the Debian backports source repository.
#
# This script is intended for native builds on Debian hosts. It builds for the
# current host architecture only and installs the Mesa package dependency closure
# needed by ika.

set -o errexit -o nounset -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_WORKDIR="${SCRIPT_DIR}/../../deb/mesa-trixie-backport"

DEFAULT_MESA_SOURCE_PACKAGE="mesa"
DEFAULT_MESA_SOURCE_SUITE="trixie-backports"
DEFAULT_MIN_MESA_VERSION="26.1"

WORKDIR="${DEFAULT_WORKDIR}"
MESA_SOURCE_PACKAGE="${MESA_SOURCE_PACKAGE:-${DEFAULT_MESA_SOURCE_PACKAGE}}"
MESA_SOURCE_SUITE="${MESA_SOURCE_SUITE:-${DEFAULT_MESA_SOURCE_SUITE}}"
MIN_MESA_VERSION="${MIN_MESA_VERSION:-${DEFAULT_MIN_MESA_VERSION}}"
ASSUME_YES=false
INSTALL_BUILT=false
STAGE_PACKAGES=true

declare -a ROOT_CMD=()
declare -A DEB_BY_PACKAGE=()
declare -a INSTALL_DEBS=()

readonly MESA_TARGET_PACKAGES=(
  libegl-mesa0
  libgbm-dev
  libgbm1
  libgl1-mesa-dri
  libglx-mesa0
  mesa-common-dev
  mesa-drm-shim
  mesa-vulkan-drivers
)

print_usage() {
  cat <<EOF
Usage: mesa-build-trixie [options]

Builds Mesa from a Debian backports source repository.

Options:
  --workdir <path>       Working directory (default: ./deb/mesa-trixie-backport)
  --source-suite <suite> Debian source suite (default: ${DEFAULT_MESA_SOURCE_SUITE})
  --source-package <pkg> Debian source package (default: ${DEFAULT_MESA_SOURCE_PACKAGE})
  --min-version <ver>    Minimum acceptable Mesa source version (default: ${DEFAULT_MIN_MESA_VERSION})
  --install              Install selected built Mesa packages after building
  --no-stage             Do not copy selected built packages to the repository root
  -y, --yes              Non-interactive apt operations when sudo is available
  -h, --help             Show this help

Notes:
  - Designed for Debian 13 trixie hosts.
  - Builds for the current host architecture only (amd64 or arm64).
  - Output .deb files are written to: <workdir>/build/
EOF
}

init_root_cmd() {
  if [[ "$(id -u)" -eq 0 ]]; then
    return
  fi

  if ! command -v sudo >/dev/null 2>&1; then
    return
  fi

  if sudo -n true >/dev/null 2>&1; then
    ROOT_CMD=(sudo -n)
    return
  fi

  if [[ -t 0 ]]; then
    ROOT_CMD=(sudo)
  fi
}

can_run_as_root() {
  [[ "$(id -u)" -eq 0 || "${#ROOT_CMD[@]}" -gt 0 ]]
}

run_as_root() {
  if [[ "$(id -u)" -eq 0 ]]; then
    "$@"
  else
    "${ROOT_CMD[@]}" "$@"
  fi
}

validate_arch() {
  case "$1" in
    amd64|arm64)
      ;;
    *)
      echo "Unsupported arch: $1 (expected amd64 or arm64)" >&2
      exit 1
      ;;
  esac
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workdir)
        [[ $# -ge 2 ]] || {
          echo "Missing value for --workdir" >&2
          exit 1
        }
        WORKDIR="$2"
        shift 2
        ;;
      --source-suite)
        [[ $# -ge 2 ]] || {
          echo "Missing value for --source-suite" >&2
          exit 1
        }
        MESA_SOURCE_SUITE="$2"
        shift 2
        ;;
      --source-package)
        [[ $# -ge 2 ]] || {
          echo "Missing value for --source-package" >&2
          exit 1
        }
        MESA_SOURCE_PACKAGE="$2"
        shift 2
        ;;
      --min-version)
        [[ $# -ge 2 ]] || {
          echo "Missing value for --min-version" >&2
          exit 1
        }
        MIN_MESA_VERSION="$2"
        shift 2
        ;;
      -y|--yes)
        ASSUME_YES=true
        shift
        ;;
      --install)
        INSTALL_BUILT=true
        shift
        ;;
      --no-stage)
        STAGE_PACKAGES=false
        shift
        ;;
      -h|--help)
        print_usage
        exit 0
        ;;
      *)
        echo "Unknown option: $1" >&2
        print_usage
        exit 1
        ;;
    esac
  done
}

require_debian() {
  if [[ ! -f /etc/os-release ]]; then
    echo "Cannot verify host distro (/etc/os-release missing)." >&2
    exit 1
  fi

  # shellcheck disable=SC1091
  . /etc/os-release
  if [[ "${ID:-}" != "debian" ]]; then
    echo "This script expects Debian. Detected ID=${ID:-unknown}." >&2
    exit 1
  fi
}

require_trixie() {
  local codename

  # shellcheck disable=SC1091
  . /etc/os-release
  codename="${VERSION_CODENAME:-}"
  if [[ "${codename}" != "trixie" ]]; then
    echo "Mesa backports source build is only supported on Debian trixie. Detected VERSION_CODENAME=${codename:-unknown}." >&2
    exit 1
  fi
}

detect_host_arch() {
  ARCH="$(dpkg --print-architecture)"
  validate_arch "${ARCH}"
}

require_tools() {
  local missing=()
  local tool

  for tool in apt-get dpkg-deb dpkg-buildpackage dpkg-parsechangelog; do
    if ! command -v "${tool}" >/dev/null 2>&1; then
      missing+=("${tool}")
    fi
  done

  if ! command -v mk-build-deps >/dev/null 2>&1; then
    missing+=(mk-build-deps)
  fi

  if [[ "${#missing[@]}" -eq 0 ]]; then
    return 0
  fi

  if ! can_run_as_root; then
    cat >&2 <<EOF
Missing prerequisite tool(s): ${missing[*]}
Root access is required to install prerequisite packages.
Run in an interactive terminal where sudo can prompt, or run as root.
EOF
    exit 1
  fi

  echo "Installing prerequisite packaging tools..."
  run_as_root env DEBIAN_FRONTEND=noninteractive apt-get update
  run_as_root env DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    build-essential \
    devscripts \
    dpkg-dev \
    equivs
}

prepare_workspace() {
  WORKDIR="$(realpath -m "${WORKDIR}")"
  BUILD_DIR="${WORKDIR}/build"
  SRC_DIR="${WORKDIR}/src"
  SOURCE_TREE=""

  mkdir -p "${BUILD_DIR}" "${SRC_DIR}"
}

install_build_tools() {
  echo "Installing build tools from configured Debian repositories..."

  run_as_root env DEBIAN_FRONTEND=noninteractive apt-get "${APT_INSTALL_OPTS[@]}" install \
    build-essential \
    devscripts \
    equivs \
    dpkg-dev
}

refresh_source_metadata() {
  echo "Refreshing Debian source metadata..."
  run_as_root env DEBIAN_FRONTEND=noninteractive apt-get update -qq
}

fetch_source() {
  local source_tree version

  rm -rf "${SRC_DIR:?}/${MESA_SOURCE_PACKAGE}-"*/
  rm -f "${SRC_DIR}"/*.dsc "${SRC_DIR}"/*.tar.* "${SRC_DIR}"/*.debian.tar.* "${SRC_DIR}"/*.orig.tar.* "${SRC_DIR}"/*.buildinfo "${SRC_DIR}"/*.changes

  echo "Downloading ${MESA_SOURCE_PACKAGE} source from ${MESA_SOURCE_SUITE}..."
  pushd "${SRC_DIR}" >/dev/null
  apt-get source -t "${MESA_SOURCE_SUITE}" "${MESA_SOURCE_PACKAGE}"
  source_tree="$(find . -mindepth 1 -maxdepth 1 -type d -name "${MESA_SOURCE_PACKAGE}-*" | sort | tail -n 1)"
  if [[ -z "${source_tree}" ]]; then
    echo "Unable to locate unpacked source directory for ${MESA_SOURCE_PACKAGE}" >&2
    exit 1
  fi
  SOURCE_TREE="$(realpath "${source_tree}")"
  popd >/dev/null

  version="$(cd "${SOURCE_TREE}" && dpkg-parsechangelog -S Version)"
  if ! dpkg --compare-versions "${version}" ge "${MIN_MESA_VERSION}"; then
    echo "${MESA_SOURCE_SUITE} has Mesa source version ${version}, expected ${MIN_MESA_VERSION} or newer." >&2
    exit 1
  fi

  echo "Source tree: ${SOURCE_TREE}"
  echo "Mesa package version: ${version}"
}

install_source_build_dependencies() {
  local apt_tool

  echo "Installing Mesa source build dependencies from ${MESA_SOURCE_SUITE}..."

  apt_tool="apt-get -t ${MESA_SOURCE_SUITE} --no-install-recommends"
  if [[ "${ASSUME_YES}" == "true" ]]; then
    apt_tool="apt-get -t ${MESA_SOURCE_SUITE} -y --no-install-recommends"
  fi

  pushd "${SOURCE_TREE}" >/dev/null
  run_as_root env DEBIAN_FRONTEND=noninteractive mk-build-deps \
    --install \
    --remove \
    --tool "${apt_tool}" \
    debian/control
  popd >/dev/null
}

build_packages() {
  echo "Building Mesa binary packages for ${ARCH}..."

  rm -f "$(dirname "${SOURCE_TREE}")"/*.deb
  rm -f "${BUILD_DIR}"/*.deb

  pushd "${SOURCE_TREE}" >/dev/null
  DEB_BUILD_OPTIONS="${DEB_BUILD_OPTIONS:-}" dpkg-buildpackage -b -uc -us
  popd >/dev/null

  echo "Collecting output .deb files..."
  find "$(dirname "${SOURCE_TREE}")" -maxdepth 1 -type f -name '*.deb' -print0 | while IFS= read -r -d '' f; do
    cp -f "${f}" "${BUILD_DIR}/"
  done

  echo
  echo "Build complete. Output packages:"
  ls -1 "${BUILD_DIR}"/*.deb
}

collect_built_package_map() {
  local deb package

  DEB_BY_PACKAGE=()
  shopt -s nullglob
  for deb in "${BUILD_DIR}"/*.deb; do
    package="$(dpkg-deb -f "${deb}" Package 2>/dev/null || true)"
    [[ -n "${package}" ]] || continue
    [[ "${package}" == *-dbgsym ]] && continue
    DEB_BY_PACKAGE["${package}"]="${deb}"
  done

  if [[ "${#DEB_BY_PACKAGE[@]}" -eq 0 ]]; then
    echo "No built .deb packages found in ${BUILD_DIR}" >&2
    exit 1
  fi
}

dependency_package_names() {
  local dep name

  tr ',' '\n' | while IFS= read -r dep; do
    dep="${dep%%|*}"
    dep="${dep%%(*}"
    dep="${dep%%[*}"
    dep="${dep#"${dep%%[![:space:]]*}"}"
    dep="${dep%"${dep##*[![:space:]]}"}"
    name="${dep%%:*}"
    if [[ "${name}" =~ ^[A-Za-z0-9][A-Za-z0-9+.-]*$ ]]; then
      printf '%s\n' "${name}"
    fi
  done
}

select_mesa_install_debs() {
  local -A selected=()
  local -a queue=()
  local -a selected_packages=()
  local pkg deb deps dep target

  collect_built_package_map

  for target in "${MESA_TARGET_PACKAGES[@]}"; do
    if [[ -z "${DEB_BY_PACKAGE[${target}]:-}" ]]; then
      echo "Built package ${target} not found in ${BUILD_DIR}" >&2
      exit 1
    fi
    queue+=("${target}")
  done

  while [[ "${#queue[@]}" -gt 0 ]]; do
    pkg="${queue[0]}"
    queue=("${queue[@]:1}")
    [[ -n "${selected[${pkg}]:-}" ]] && continue
    [[ -n "${DEB_BY_PACKAGE[${pkg}]:-}" ]] || continue

    selected["${pkg}"]=1
    deb="${DEB_BY_PACKAGE[${pkg}]}"
    deps="$(
      dpkg-deb -f "${deb}" Pre-Depends 2>/dev/null || true
      dpkg-deb -f "${deb}" Depends 2>/dev/null || true
    )"

    while IFS= read -r dep; do
      [[ -n "${dep}" ]] || continue
      if [[ -n "${DEB_BY_PACKAGE[${dep}]:-}" && -z "${selected[${dep}]:-}" ]]; then
        queue+=("${dep}")
      fi
    done < <(dependency_package_names <<<"${deps}")
  done

  mapfile -t selected_packages < <(printf '%s\n' "${!selected[@]}" | sort)
  INSTALL_DEBS=()
  for pkg in "${selected_packages[@]}"; do
    INSTALL_DEBS+=("${DEB_BY_PACKAGE[${pkg}]}")
  done
}

install_built_packages() {
  select_mesa_install_debs

  echo
  echo "Installing built Mesa packages:"
  printf '  %s\n' "${INSTALL_DEBS[@]}"
  run_as_root env DEBIAN_FRONTEND=noninteractive apt-get "${APT_INSTALL_OPTS[@]}" install --no-install-recommends "${INSTALL_DEBS[@]}"
}

stage_built_packages() {
  local repo_root f
  repo_root="$(realpath "${SCRIPT_DIR}/../..")"

  select_mesa_install_debs

  echo
  echo "Staging selected Mesa packages to ${repo_root}/ for packaging..."
  for f in "${INSTALL_DEBS[@]}"; do
    cp -f "${f}" "${repo_root}/"
    echo "  $(basename "${f}")"
  done
}

main() {
  parse_args "$@"
  require_debian
  require_trixie
  detect_host_arch
  init_root_cmd

  if ! can_run_as_root; then
    cat >&2 <<'EOF'
Root access is required to install build dependencies.
Run in an interactive terminal where sudo can prompt, or run as root.
EOF
    exit 1
  fi

  require_tools
  prepare_workspace

  if [[ "${ASSUME_YES}" == "true" ]]; then
    APT_INSTALL_OPTS=(-y)
  else
    APT_INSTALL_OPTS=()
  fi

  install_build_tools
  refresh_source_metadata
  fetch_source
  install_source_build_dependencies
  build_packages
  if [[ "${INSTALL_BUILT}" == "true" ]]; then
    install_built_packages
  fi
  if [[ "${STAGE_PACKAGES}" == "true" ]]; then
    stage_built_packages
  fi
}

main "$@"
