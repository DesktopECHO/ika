#!/usr/bin/env bash

# Build updated libvulkan packages from a Debian Salsa packaging commit.
#
# This script is intended for native builds on Debian trixie hosts only. It
# builds for the current host architecture and installs the Vulkan loader
# packages needed by ika without enabling Debian testing/backports repositories.

set -o errexit -o nounset -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_WORKDIR="${SCRIPT_DIR}/../../deb/libvulkan1-salsa"
DEFAULT_VULKAN_REPO_URL="https://salsa.debian.org/xorg-team/vulkan/vulkan-loader.git"
DEFAULT_VULKAN_COMMIT="e3a3df62e0b7e9b12dacb626a8d554a47ad9ed2d"

WORKDIR="${DEFAULT_WORKDIR}"
VULKAN_REPO_URL="${VULKAN_REPO_URL:-${DEFAULT_VULKAN_REPO_URL}}"
VULKAN_COMMIT="${VULKAN_COMMIT:-${DEFAULT_VULKAN_COMMIT}}"
ASSUME_YES=false
INSTALL_BUILT=false
STAGE_PACKAGES=true

declare -a ROOT_CMD=()

print_usage() {
  cat <<EOF
Usage: vulkan-build-trixie [options]

Builds Vulkan loader packages from the Debian Salsa packaging commit:
  ${DEFAULT_VULKAN_COMMIT}

Options:
  --workdir <path>       Working directory (default: ./deb/libvulkan1-salsa)
  --repo-url <url>       Vulkan loader packaging git URL (default: ${DEFAULT_VULKAN_REPO_URL})
  --commit <sha>         Vulkan loader packaging commit (default: ${DEFAULT_VULKAN_COMMIT})
  --install              Install built libvulkan packages after building
  --no-stage             Do not copy built packages to the repository root
  -y, --yes              Non-interactive apt operations when sudo is available
  -h, --help             Show this help

Examples:
  ./tools/buildutils/vulkan-build-trixie
  ./tools/buildutils/vulkan-build-trixie --workdir ~/build/libvulkan

Notes:
  - Designed for Debian trixie hosts only.
  - Builds for the current host architecture only (amd64 or arm64).
  - Output .deb files are written to: <workdir>/build/
EOF
}

init_root_cmd() {
  if [[ "$(id -u)" -eq 0 ]]; then
    return
  fi

  if ! command -v sudo >/dev/null 2>&1; then
    return
  fi

  if sudo -n true >/dev/null 2>&1; then
    ROOT_CMD=(sudo -n)
    return
  fi

  if [[ -t 0 ]]; then
    ROOT_CMD=(sudo)
  fi
}

can_run_as_root() {
  [[ "$(id -u)" -eq 0 || "${#ROOT_CMD[@]}" -gt 0 ]]
}

run_as_root() {
  if [[ "$(id -u)" -eq 0 ]]; then
    "$@"
  else
    "${ROOT_CMD[@]}" "$@"
  fi
}

validate_arch() {
  case "$1" in
    amd64|arm64)
      ;;
    *)
      echo "Unsupported arch: $1 (expected amd64 or arm64)" >&2
      exit 1
      ;;
  esac
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workdir)
        [[ $# -ge 2 ]] || {
          echo "Missing value for --workdir" >&2
          exit 1
        }
        WORKDIR="$2"
        shift 2
        ;;
      --repo-url)
        [[ $# -ge 2 ]] || {
          echo "Missing value for --repo-url" >&2
          exit 1
        }
        VULKAN_REPO_URL="$2"
        shift 2
        ;;
      --commit)
        [[ $# -ge 2 ]] || {
          echo "Missing value for --commit" >&2
          exit 1
        }
        VULKAN_COMMIT="$2"
        shift 2
        ;;
      -y|--yes)
        ASSUME_YES=true
        shift
        ;;
      --install)
        INSTALL_BUILT=true
        shift
        ;;
      --no-stage)
        STAGE_PACKAGES=false
        shift
        ;;
      -h|--help)
        print_usage
        exit 0
        ;;
      *)
        echo "Unknown option: $1" >&2
        print_usage
        exit 1
        ;;
    esac
  done
}

require_debian() {
  if [[ ! -f /etc/os-release ]]; then
    echo "Cannot verify host distro (/etc/os-release missing)." >&2
    exit 1
  fi

  # shellcheck disable=SC1091
  . /etc/os-release
  if [[ "${ID:-}" != "debian" ]]; then
    echo "This script expects Debian. Detected ID=${ID:-unknown}." >&2
    exit 1
  fi
}

require_trixie() {
  local codename

  # shellcheck disable=SC1091
  . /etc/os-release
  codename="${VERSION_CODENAME:-}"
  if [[ "${codename}" != "trixie" ]]; then
    echo "This script expects Debian trixie. Detected VERSION_CODENAME=${codename:-unknown}." >&2
    exit 1
  fi
}

detect_host_arch() {
  ARCH="$(dpkg --print-architecture)"
  validate_arch "${ARCH}"
}

require_tools() {
  local missing=()
  local tool

  for tool in apt-get dpkg-buildpackage dpkg-deb dpkg-parsechangelog git; do
    if ! command -v "${tool}" >/dev/null 2>&1; then
      missing+=("${tool}")
    fi
  done

  if ! command -v mk-build-deps >/dev/null 2>&1; then
    missing+=(mk-build-deps)
  fi

  if [[ "${#missing[@]}" -eq 0 ]]; then
    return 0
  fi

  if ! can_run_as_root; then
    cat >&2 <<EOF
Missing prerequisite tool(s): ${missing[*]}
Root access is required to install prerequisite packages.
Run in an interactive terminal where sudo can prompt, or run as root.
EOF
    exit 1
  fi

  echo "Installing prerequisite packaging tools..."
  run_as_root env DEBIAN_FRONTEND=noninteractive apt-get update
  run_as_root env DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    build-essential \
    devscripts \
    dpkg-dev \
    equivs \
    git
}

prepare_workspace() {
  WORKDIR="$(realpath -m "${WORKDIR}")"
  BUILD_DIR="${WORKDIR}/build"
  SRC_DIR="${WORKDIR}/src"
  SOURCE_TREE="${SRC_DIR}/vulkan-loader-${VULKAN_COMMIT:0:12}"

  mkdir -p "${BUILD_DIR}" "${SRC_DIR}"

  if [[ "${ASSUME_YES}" == "true" ]]; then
    APT_INSTALL_OPTS=(-y)
  else
    APT_INSTALL_OPTS=()
  fi
}

install_build_tools() {
  echo "Installing build tools from configured Debian repositories..."

  run_as_root env DEBIAN_FRONTEND=noninteractive apt-get "${APT_INSTALL_OPTS[@]}" install \
    build-essential \
    devscripts \
    equivs \
    dpkg-dev
}

fetch_source() {
  local current_commit=""

  if [[ -d "${SOURCE_TREE}/.git" ]]; then
    current_commit="$(git -C "${SOURCE_TREE}" rev-parse HEAD 2>/dev/null || true)"
  fi

  if [[ "${current_commit}" == "${VULKAN_COMMIT}" ]]; then
    echo "Reusing Vulkan loader source tree at ${SOURCE_TREE}"
    return 0
  fi

  rm -rf "${SOURCE_TREE}"
  mkdir -p "${SOURCE_TREE}"

  echo "Fetching Vulkan loader packaging commit ${VULKAN_COMMIT}..."
  git -C "${SOURCE_TREE}" init -q
  git -C "${SOURCE_TREE}" remote add origin "${VULKAN_REPO_URL}"
  git -C "${SOURCE_TREE}" -c protocol.version=2 fetch --depth=1 --filter=blob:none origin "${VULKAN_COMMIT}"
  git -C "${SOURCE_TREE}" checkout -q --force FETCH_HEAD

  current_commit="$(git -C "${SOURCE_TREE}" rev-parse HEAD)"
  if [[ "${current_commit}" != "${VULKAN_COMMIT}" ]]; then
    echo "Fetched ${current_commit}, expected ${VULKAN_COMMIT}" >&2
    exit 1
  fi

  echo "Source tree: ${SOURCE_TREE}"
  echo "Vulkan loader package version: $(cd "${SOURCE_TREE}" && dpkg-parsechangelog -S Version)"
}

install_source_build_dependencies() {
  local apt_tool

  echo "Installing Vulkan loader source build dependencies from configured Debian repositories..."

  apt_tool="apt-get --no-install-recommends"
  if [[ "${ASSUME_YES}" == "true" ]]; then
    apt_tool="apt-get -y --no-install-recommends"
  fi

  pushd "${SOURCE_TREE}" >/dev/null
  run_as_root env DEBIAN_FRONTEND=noninteractive mk-build-deps \
    --install \
    --remove \
    --tool "${apt_tool}" \
    debian/control
  popd >/dev/null
}

build_packages() {
  echo "Building Vulkan loader binary packages for ${ARCH}..."

  rm -f "$(dirname "${SOURCE_TREE}")"/*.deb
  rm -f "${BUILD_DIR}"/*.deb

  pushd "${SOURCE_TREE}" >/dev/null
  DEB_BUILD_OPTIONS="${DEB_BUILD_OPTIONS:-}" dpkg-buildpackage -b -uc -us
  popd >/dev/null

  echo "Collecting output .deb files..."
  find "$(dirname "${SOURCE_TREE}")" -maxdepth 1 -type f -name '*.deb' -print0 | while IFS= read -r -d '' f; do
    cp -f "${f}" "${BUILD_DIR}/"
  done

  echo
  echo "Build complete. Output packages:"
  ls -1 "${BUILD_DIR}"/*.deb
}

install_built_packages() {
  shopt -s nullglob
  local -a all_debs=("${BUILD_DIR}"/*.deb)
  if [[ "${#all_debs[@]}" -eq 0 ]]; then
    echo "No built .deb packages found in ${BUILD_DIR}" >&2
    exit 1
  fi

  local -a target_packages=(libvulkan1 libvulkan-dev)
  local -a install_debs=()
  local deb package target found
  for target in "${target_packages[@]}"; do
    found=""
    for deb in "${all_debs[@]}"; do
      package="$(dpkg-deb -f "${deb}" Package 2>/dev/null || true)"
      if [[ "${package}" == "${target}" ]]; then
        found="${deb}"
        break
      fi
    done
    if [[ -z "${found}" ]]; then
      echo "Built package ${target} not found in ${BUILD_DIR}" >&2
      exit 1
    fi
    install_debs+=("${found}")
  done

  echo
  echo "Installing built libvulkan1 and libvulkan-dev packages..."
  run_as_root env DEBIAN_FRONTEND=noninteractive apt-get "${APT_INSTALL_OPTS[@]}" install --no-install-recommends "${install_debs[@]}"
}

stage_built_packages() {
  local repo_root dest f
  repo_root="$(realpath "${SCRIPT_DIR}/../..")"

  shopt -s nullglob
  local -a debs=("${BUILD_DIR}"/*.deb)
  if [[ "${#debs[@]}" -eq 0 ]]; then
    echo "No built .deb packages found in ${BUILD_DIR}" >&2
    exit 1
  fi

  echo
  echo "Staging built vulkan packages to ${repo_root}/ for packaging..."
  for f in "${debs[@]}"; do
    cp -f "${f}" "${repo_root}/"
    echo "  $(basename "${f}")"
  done
}

main() {
  parse_args "$@"
  require_debian
  require_trixie
  detect_host_arch
  init_root_cmd
  require_tools
  prepare_workspace

  if ! can_run_as_root; then
    cat >&2 <<'EOF'
Root access is required to install build dependencies.
Run in an interactive terminal where sudo can prompt, or run as root.
EOF
    exit 1
  fi

  install_build_tools
  fetch_source
  install_source_build_dependencies
  build_packages
  if [[ "${INSTALL_BUILT}" == "true" ]]; then
    install_built_packages
  fi
  if [[ "${STAGE_PACKAGES}" == "true" ]]; then
    stage_built_packages
  fi
}

main "$@"
