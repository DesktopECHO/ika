DEFAULT_CVD_PRODUCT_OUT="/usr/share/cuttlefish-common/lineageos"
PACKAGED_SCRCPY_BIN="/usr/lib/cuttlefish-common/bin/scrcpy"
PACKAGED_SCRCPY_SERVER="/usr/lib/cuttlefish-common/share/scrcpy/scrcpy-server"
PACKAGED_GETCHROMIUM_BIN="/usr/lib/cuttlefish-common/bin/getchromium"
SCRCPY_ICON_DIR_DEFAULT="/usr/lib/cuttlefish-common/share/icons/hicolor/256x256/apps"

# Checks if a flag was supplied by the user in the arguments
user_supplied_flag() {
  local flag="$1"
  shift
  local arg
  for arg in "$@"; do
    case "${arg}" in
      --${flag}=*|--${flag}|-${flag}=*|-${flag})
        return 0
        ;;
    esac
  done
  return 1
}

packaged_scrcpy_pids() {
  local pid
  local proc_uid
  local argv0
  local exe_path

  for proc in /proc/[0-9]*; do
    [[ -d "${proc}" ]] || continue
    pid="${proc##*/}"
    proc_uid="$(stat -c '%u' "${proc}" 2>/dev/null || true)"
    [[ "${proc_uid}" == "${UID}" ]] || continue

    argv0="$(tr '\0' '\n' <"${proc}/cmdline" 2>/dev/null | head -n1 || true)"
    if [[ "${argv0}" == "${SCRCPY_BIN:-${PACKAGED_SCRCPY_BIN}}" \
        || "${argv0}" == "${PACKAGED_SCRCPY_BIN}" ]]; then
      printf '%s\n' "${pid}"
      continue
    fi

    exe_path="$(readlink -f "${proc}/exe" 2>/dev/null || true)"
    exe_path="${exe_path% (deleted)}"
    if [[ "${exe_path}" == "${SCRCPY_BIN:-${PACKAGED_SCRCPY_BIN}}" \
        || "${exe_path}" == "${PACKAGED_SCRCPY_BIN}" ]]; then
      printf '%s\n' "${pid}"
    fi
  done
}

has_packaged_scrcpy() {
  local pids

  pids="$(packaged_scrcpy_pids)"
  [[ -n "${pids}" ]]
}

stop_startup_packaged_scrcpy() {
  local pid
  local deadline

  while read -r pid; do
    [[ -n "${pid}" ]] || continue

    kill "${pid}" >/dev/null 2>&1 || true

    deadline=$((SECONDS + 5))
    while kill -0 "${pid}" >/dev/null 2>&1; do
      if (( SECONDS >= deadline )); then
        printf '[%s] packaged scrcpy pid %s did not exit cleanly; forcing termination\n' "${SCRIPT_NAME}" "${pid}" >&2
        kill -9 "${pid}" >/dev/null 2>&1 || true
        sleep 0.5
        break
      fi
      sleep 0.2
    done
  done < <(packaged_scrcpy_pids | sort -u)
}

count_performance_cores() {
  performance_core_ids | wc -l
}

performance_core_ids() {
  local max_cap
  local path
  local cap
  local cpu
  max_cap="$(cat /sys/devices/system/cpu/cpu*/cpu_capacity 2>/dev/null | sort -n | tail -1)"
  [[ -n "${max_cap}" ]] || return 0

  for path in /sys/devices/system/cpu/cpu[0-9]*/cpu_capacity; do
    [[ -r "${path}" ]] || continue
    cap="$(<"${path}")"
    [[ "${cap}" == "${max_cap}" ]] || continue
    cpu="${path%/cpu_capacity}"
    cpu="${cpu##*/cpu}"
    printf '%s\n' "${cpu}"
  done | sort -n
}

reserved_host_core_list() {
  local -a cores=()
  local count
  mapfile -t cores < <(performance_core_ids)
  count="${#cores[@]}"
  (( count > 2 )) || return 0
  printf '%s,%s\n' "${cores[count - 2]}" "${cores[count - 1]}"
}

# Upper bound on the auto-selected guest vCPU count. The default heuristic
# never exceeds this; pass --cpus= to request more.
readonly DEFAULT_GUEST_CPU_CAP=12

default_guest_cpus() {
  local cores guest_cpus
  cores="$(count_performance_cores)"
  cores="${cores//[!0-9]/}"

  # Homogeneous hosts (x86_64, or ARM without cpu_capacity) report no
  # performance cores; fall back to the online (available) CPU count.
  if [[ -z "${cores}" ]] || (( cores <= 0 )); then
    cores="$(nproc 2>/dev/null || true)"
    cores="${cores//[!0-9]/}"
  fi

  # Reserve 2 cores for the host and floor at 1. Last-ditch default of 2 if
  # neither probe produced a usable count.
  if [[ -z "${cores}" ]] || (( cores <= 0 )); then
    guest_cpus=2
  elif (( cores > 2 )); then
    guest_cpus=$((cores - 2))
  else
    guest_cpus=1
  fi

  # Cap the auto-selected default; --cpus= bypasses this entirely.
  (( guest_cpus <= DEFAULT_GUEST_CPU_CAP )) || guest_cpus=${DEFAULT_GUEST_CPU_CAP}

  echo "${guest_cpus}"
}

