log() {
  printf '[%s] %s\n' "${SCRIPT_NAME}" "$*" >&2
}

die() {
  log "error: $*"
  if [[ -n "${CONSOLE_FAILURE_MESSAGE:-}" ]]; then
    printf '%s\n' "${CONSOLE_FAILURE_MESSAGE}" >&3
  fi
  exit 1
}

ensure_open_file_limit() {
  local min_open_files="${IKA_MIN_OPEN_FILES:-65536}"
  local soft_limit
  local hard_limit

  if [[ ! "${min_open_files}" =~ ^[1-9][0-9]*$ ]]; then
    log "invalid IKA_MIN_OPEN_FILES='${min_open_files}'; using 65536"
    min_open_files="65536"
  fi

  soft_limit="$(ulimit -Sn 2>/dev/null || true)"
  hard_limit="$(ulimit -Hn 2>/dev/null || true)"
  [[ -n "${soft_limit}" && -n "${hard_limit}" ]] || return 0
  [[ "${soft_limit}" == "unlimited" ]] && return 0

  if [[ "${soft_limit}" =~ ^[0-9]+$ ]] && (( soft_limit >= min_open_files )); then
    return 0
  fi

  if [[ "${hard_limit}" != "unlimited" ]]; then
    if [[ ! "${hard_limit}" =~ ^[0-9]+$ ]]; then
      log "could not parse open-file hard limit '${hard_limit}'"
      return 0
    fi
    if (( hard_limit < min_open_files )); then
      log "open-file soft limit is ${soft_limit}, but hard limit ${hard_limit} prevents raising it to ${min_open_files}"
      return 0
    fi
  fi

  if ulimit -Sn "${min_open_files}" 2>/dev/null; then
    log "raised open-file soft limit: ${soft_limit} -> $(ulimit -Sn)"
  else
    log "could not raise open-file soft limit from ${soft_limit} to ${min_open_files}"
  fi
}

normalize_gfxstream_vulkan_mode() {
  local mode="${1,,}"

  case "${mode}" in
    ""|auto)
      echo "auto"
      ;;
    1|true|yes|on|enable|enabled)
      echo "on"
      ;;
    0|false|no|off|disable|disabled)
      echo "off"
      ;;
    *)
      die "invalid gfxstream Vulkan mode '${1}' (expected auto, on, or off)"
      ;;
  esac
}

respond() {
  printf '%s\n' "$*"
}

respond_console() {
  printf '%s\n' "$*" >&3
}

confirm_reset() {
  local reply

  printf 'WARNING: This will "Factory Reset" your Android virtual device, type "Y" to continue. ' >&3
  if ! IFS= read -r -n 1 reply; then
    printf '\n' >&3
    respond_console "Reset aborted."
    return 1
  fi
  printf '\n' >&3

  if [[ "${reply}" != "Y" && "${reply}" != "y" ]]; then
    respond_console "Reset aborted."
    return 1
  fi

  return 0
}

normalize_data_gb() {
  local data_gb="$1"

  if [[ ! "${data_gb}" =~ ^[1-9][0-9]*$ ]]; then
    die "DATA_GB must be a positive whole number of gigabytes"
  fi

  printf '%s\n' "${data_gb}"
}

data_gb_to_mib() {
  local data_gb="$1"
  printf '%s\n' "$((data_gb * 1000000000 / 1048576))"
}

parse_start_options() {
  local -n fullscreen_mode_ref="$1"
  local -n game_mode_ref="$2"
  local -n start_args_ref="$3"
  shift 3

  fullscreen_mode_ref="false"
  game_mode_ref="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--fullscreen)
        fullscreen_mode_ref="true"
        shift
        ;;
      --game)
        fullscreen_mode_ref="true"
        game_mode_ref="true"
        shift
        ;;
      --gfxstream_vulkan=*)
        GFXSTREAM_VULKAN_MODE="$(normalize_gfxstream_vulkan_mode "${1#*=}")"
        export GFXSTREAM_VULKAN="${GFXSTREAM_VULKAN_MODE}"
        shift
        ;;
      --gfxstream_vulkan)
        shift
        [[ $# -gt 0 ]] || die "--gfxstream_vulkan requires a value: auto, on, or off"
        GFXSTREAM_VULKAN_MODE="$(normalize_gfxstream_vulkan_mode "$1")"
        export GFXSTREAM_VULKAN="${GFXSTREAM_VULKAN_MODE}"
        shift
        ;;
      --data_gb=*)
        DATA_GB="$(normalize_data_gb "${1#*=}")"
        export DATA_GB
        shift
        ;;
      --data_gb)
        shift
        [[ $# -gt 0 ]] || die "--data_gb requires a value"
        DATA_GB="$(normalize_data_gb "$1")"
        export DATA_GB
        shift
        ;;
      --ika_scrcpy=*)
        IKA_SCRCPY="${1#*=}"
        export IKA_SCRCPY
        shift
        ;;
      --ika_scrcpy)
        shift
        [[ $# -gt 0 ]] || die "--ika_scrcpy requires a value"
        IKA_SCRCPY="$1"
        export IKA_SCRCPY
        shift
        ;;
      *)
        start_args_ref+=("$1")
        shift
        ;;
    esac
  done
}

console_notify() {
  local action="$1"
  local elapsed_sec="$2"
  local launcher_log_path
  if [[ "${action}" == "started" ]]; then
    launcher_log_path="${CVD_LAUNCHER_LOG}"
    if [[ "${launcher_log_path}" == "${HOME}/"* ]]; then
      launcher_log_path="~/${launcher_log_path#"${HOME}/"}"
    fi
    printf 'Device online in %ss: %s\n' "${elapsed_sec}" "${launcher_log_path}" >&3
    return 0
  fi
  printf 'Android virtual device %s in %ss.\n' "${action}" "${elapsed_sec}" >&3
}

run_timed_operation() {
  local action="$1"
  shift

  local start_epoch
  local elapsed_sec

  start_epoch="$(date +%s)"
  "$@"
  elapsed_sec="$(( $(date +%s) - start_epoch ))"

  console_notify "${action}" "${elapsed_sec}"
}

