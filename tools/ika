usage() {
  local output_fd="${1:-1}"
  cat >&"${output_fd}" <<EOF

Usage:

  ${SCRIPT_NAME} start [-f|--fullscreen|--game] [--gfxstream_vulkan=auto|on|off] [--data_gb=GB] [--ika_scrcpy=ARGS] [--setting=arg] ...
  ${SCRIPT_NAME} stop
  ${SCRIPT_NAME} restart [-f|--fullscreen|--game] [--gfxstream_vulkan=auto|on|off] [--data_gb=GB] [--ika_scrcpy=ARGS] ...
  ${SCRIPT_NAME} reset [Delete everything and start fresh]

Example:

  ${SCRIPT_NAME} start --gpu_mode=guest_swiftshader --cpus=2 --memory_mb=2048 --dpi=240 --fullscreen
  ${SCRIPT_NAME} start --game
  ${SCRIPT_NAME} start --data_gb=128
  ${SCRIPT_NAME} restart --gpu_mode=gfxstream_guest_angle_host_swiftshader
  ${SCRIPT_NAME} restart --gfxstream_vulkan=on
  ${SCRIPT_NAME} restart --ika_scrcpy="--no-clipboard-autosync"

Options:

  --game                 Start scrcpy fullscreen with UHID gamepad, keyboard,
                         and mouse input.

Environment:

  GFXSTREAM_VULKAN       auto, on, or off. auto disables gfxstream Vulkan
                         only on Apple Silicon 16K-page hosts or when the
                         primary host Vulkan device is llvmpipe; on forces
                         GLES+Vulkan; off forces GLES-only gfxstream.
                         On Apple Silicon 16K-page hosts, on also routes
                         host-visible guest Vulkan memory through udmabuf-backed
                         dma-buf (the path the Apple GPU supports).
  DATA_GB                Size of the next fresh userdata image, in GB.
                         Existing VM data must be reset first.
  IKA_SCRCPY             Extra whitespace-separated args appended to scrcpy.
                         Equivalent command-line option: --ika_scrcpy=ARGS
                         (example: --keyboard=uhid --no-clipboard-autosync)

  NOTE: All other parameters are passed directly to Cuttlefish.

EOF
}

shell_join() {
  local joined
  printf -v joined '%q ' "$@"
  printf '%s' "${joined% }"
}

latest_launcher_log_message() {
  local launcher_log="$1"
  local min_mtime="$2"
  local pattern="$3"
  local log_mtime

  [[ -f "${launcher_log}" ]] || return 1

  log_mtime="$(stat -c '%Y' "${launcher_log}" 2>/dev/null || echo 0)"
  [[ "${log_mtime}" -ge "${min_mtime}" ]] || return 1

  grep -F "${pattern}" "${launcher_log}" | tail -n 1 || true
}

maybe_respond_crosvm_command() {
  local launcher_log="$1"
  local min_mtime="$2"
  local line
  local command

  line="$(latest_launcher_log_message "${launcher_log}" "${min_mtime}" "crosvm launch command:")"
  [[ -n "${line}" ]] || return 1

  command="${line#*"crosvm launch command: "}"
  respond "[${SCRIPT_NAME}] crosvm launch command: ${command}"
  return 0
}

emit_launch_command() {
  local launch_command
  local -a env_args=(env)

  append_cvd_env_args env_args

  launch_command="$(
    shell_join \
      "${env_args[@]}" \
      "${CVD_BIN}" \
      "$@"
  )"

  log "launch command: cd $(printf '%q' "${CVD_PRODUCT_OUT}") && ${launch_command}"
}

resolve_scrcpy_dpi() {
  local explicit_dpi="${1:-}"
  local size
  local width
  local dpi

  if [[ -n "${explicit_dpi}" ]]; then
    printf '%s\n' "${explicit_dpi}"
    return 0
  fi

  if [[ "${IKADPI:-}" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "${IKADPI}"
    return 0
  fi

  size="$(host_display_size || true)"
  if [[ ! "${size}" =~ ^([0-9]+)x[0-9]+$ ]]; then
    die "could not determine host display width for automatic DPI"
  fi

  # Heuristic: DPI = (native display width / 10)
  width="${BASH_REMATCH[1]}"
  dpi=$(( width / 10 - 24 ))
  dpi=$(( dpi / 8 * 8 ))
  if (( dpi < 96 )); then
    dpi=96
  fi

  printf '%s\n' "${dpi}"
}

split_start_args() {
  local -n args_array="$1"
  local -n scrcpy_dpi_ref="$2"
  shift 2
  local dpi_user_supplied="false"

  scrcpy_dpi_ref=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dpi=*)
        scrcpy_dpi_ref="${1#*=}"
        dpi_user_supplied="true"
        args_array+=("$1")
        shift
        ;;
      --dpi)
        args_array+=("$1")
        shift
        [[ $# -gt 0 ]] || die "--dpi requires a value"
        scrcpy_dpi_ref="$1"
        dpi_user_supplied="true"
        args_array+=("$1")
        shift
        ;;
      *)
        args_array+=("$1")
        shift
        ;;
    esac
  done

  scrcpy_dpi_ref="$(resolve_scrcpy_dpi "${scrcpy_dpi_ref}")"
  if [[ "${dpi_user_supplied}" != "true" ]]; then
    args_array+=("--dpi=${scrcpy_dpi_ref}")
  fi
}

# Largest "current" Wayland output mode as WxH. Probed at most once per run and
# cached: a single start queries it more than once (DPI heuristic + display
# ceiling) and spawning wayland-info is comparatively expensive.
_host_display_size_probed=""
_host_display_size_value=""
host_display_size() {
  if [[ -z "${_host_display_size_probed}" ]]; then
    _host_display_size_probed="yes"
    if command -v wayland-info >/dev/null 2>&1; then
      _host_display_size_value="$(
        wayland-info 2>/dev/null | awk '
          /mode:/ { in_mode = 1; width = 0; height = 0; next }
          in_mode && /width:/ {
            w = $0; sub(/.*width:[[:space:]]*/, "", w);  width  = int(w)
            h = $0; sub(/.*height:[[:space:]]*/, "", h); height = int(h)
          }
          in_mode && /flags:/ {
            if (/current/ && width && height) {
              area = width * height
              if (area > best_area) {
                best_area = area; best_width = width; best_height = height
              }
            }
            in_mode = 0
          }
          END { if (best_width && best_height) printf "%sx%s\n", best_width, best_height }
        ' || true
      )"
    fi
  fi

  [[ -n "${_host_display_size_value}" ]] || return 1
  printf '%s\n' "${_host_display_size_value}"
}

_host_display_logical_size_probed=""
_host_display_logical_size_value=""
host_display_logical_size() {
  if [[ -z "${_host_display_logical_size_probed}" ]]; then
    _host_display_logical_size_probed="yes"
    if command -v wayland-info >/dev/null 2>&1; then
      _host_display_logical_size_value="$(
        wayland-info 2>/dev/null | awk '
          /logical_width:/ {
            line = $0
            sub(/.*logical_width:[[:space:]]*/, "", line)
            split(line, width_parts, ",")
            width = int(width_parts[1])

            line = $0
            sub(/.*logical_height:[[:space:]]*/, "", line)
            height = int(line)

            if (width && height) {
              area = width * height
              if (area > best_area) {
                best_area = area; best_width = width; best_height = height
              }
            }
          }
          END { if (best_width && best_height) printf "%sx%s\n", best_width, best_height }
        ' || true
      )"
    fi
  fi

  [[ -n "${_host_display_logical_size_value}" ]] || return 1
  printf '%s\n' "${_host_display_logical_size_value}"
}

default_scrcpy_window_size() {
  local size
  local width
  local height
  local host_width
  local host_height

  size="$(host_display_logical_size || true)"
  if [[ "${size}" =~ ^([0-9]+)x([0-9]+)$ ]]; then
    host_width="${BASH_REMATCH[1]}"
    host_height="${BASH_REMATCH[2]}"
    width=$(( host_width * 85 / 100 ))
    height=$(( host_height * 85 / 100 ))
  else
    width=1280
    height=720
  fi

  printf '%sx%s\n' "${width}" "${height}"
}

has_display_size_override() {
  local flag

  for flag in display display0 display1 display2 display3 \
              displays_textproto displays_binproto x_res y_res; do
    if user_supplied_flag "${flag}" "$@"; then
      return 0
    fi
  done

  return 1
}

append_default_display_arg() {
  local -n args_array="$1"
  local dpi="$2"
  shift 2
  local size
  local width
  local height

  if has_display_size_override "$@"; then
    return 0
  fi

  size="$(host_display_size || true)"
  if [[ ! "${size}" =~ ^([0-9]+)x([0-9]+)$ ]]; then
    log "could not determine host display size; leaving Cuttlefish display defaults unchanged"
    return 0
  fi

  width="${BASH_REMATCH[1]}"
  height="${BASH_REMATCH[2]}"

  args_array+=("--display=width=${width},height=${height},dpi=${dpi},refresh_rate_hz=60")
  log "display ceiling: ${width}x${height}/${dpi}"
}

is_apple_silicon_16k_host() {
  local arch
  local page_size

  host_is_arm64 || return 1

  page_size="$(getconf PAGESIZE 2>/dev/null || echo 0)"
  [[ "${page_size}" =~ ^[0-9]+$ ]] || return 1
  (( page_size > 4096 )) || return 1

  [[ -r /proc/device-tree/compatible ]] || return 1
  tr '\0' '\n' < /proc/device-tree/compatible 2>/dev/null | grep -q '^apple,'
}

host_is_arm64() {
  local arch
  arch="$(uname -m 2>/dev/null || true)"
  [[ "${arch}" == "aarch64" || "${arch}" == "arm64" ]]
}

host_page_size() {
  local page_size
  page_size="$(getconf PAGESIZE 2>/dev/null || true)"
  if [[ ! "${page_size}" =~ ^[0-9]+$ ]]; then
    page_size=0
  fi
  printf '%s\n' "${page_size}"
}

normalize_kernel_page_size_mode() {
  local mode="${1:-auto}"
  mode="${mode,,}"

  case "${mode}" in
    ""|auto)
      printf '%s\n' "auto"
      ;;
    4|4k|4096)
      printf '%s\n' "4k"
      ;;
    16|16k|16384)
      printf '%s\n' "16k"
      ;;
    *)
      die "invalid IKA_KERNEL_PAGE_SIZE='${1}' (expected auto, 4k, or 16k)"
      ;;
  esac
}

arm64_kernel_page_size() {
  local mode
  local page_size

  host_is_arm64 || return 1

  mode="$(normalize_kernel_page_size_mode "${IKA_KERNEL_PAGE_SIZE:-auto}")"
  case "${mode}" in
    4k|16k)
      printf '%s\n' "${mode}"
      ;;
    auto)
      page_size="$(host_page_size)"
      if (( page_size > 4096 )); then
        printf '%s\n' "16k"
      else
        printf '%s\n' "4k"
      fi
      ;;
  esac
}

append_arm64_kernel_page_args() {
  local -n args_array="$1"
  shift
  local selected_page_size
  local page_size
  local boot_16k

  host_is_arm64 || return 0

  if user_supplied_flag "use_16k" "$@" \
      || user_supplied_flag "boot_image" "$@" \
      || user_supplied_flag "kernel_path" "$@" \
      || user_supplied_flag "initramfs_path" "$@" \
      || user_supplied_flag "vendor_boot_image" "$@"; then
    log "arm64 kernel page-size auto-selection skipped because boot/kernel args were supplied"
    return 0
  fi

  selected_page_size="$(arm64_kernel_page_size)"
  page_size="$(host_page_size)"

  case "${selected_page_size}" in
    16k)
      boot_16k="${CVD_PRODUCT_OUT}/boot_16k.img"
      [[ -s "${boot_16k}" ]] || \
        die "ARM64 host page size is ${page_size} bytes, but ${boot_16k} is missing"

      args_array+=("--boot_image=${boot_16k}")
      log "arm64 kernel page-size: ${page_size} byte host pages -> boot_16k.img"
      ;;
    4k)
      log "arm64 kernel page-size: ${page_size} byte host pages -> boot.img"
      ;;
  esac
}

primary_vulkan_device_is_llvmpipe() {
  local summary
  local primary_device

  command -v vulkaninfo >/dev/null 2>&1 || return 1

  summary="$(vulkaninfo --summary 2>/dev/null || true)"
  [[ -n "${summary}" ]] || return 1

  primary_device="$(
    awk '
      /^GPU[0-9]+:/ {
        if (seen) {
          exit
        }
        seen = 1
        next
      }
      seen {
        print
      }
    ' <<<"${summary}"
  )"
  [[ -n "${primary_device}" ]] || return 1

  grep -Eiq '(^[[:space:]]*(deviceName|driverName|driverID)[[:space:]]*=.*llvmpipe|DRIVER_ID_MESA_LLVMPIPE)' <<<"${primary_device}"
}

start_arg_value() {
  local flag="$1"
  local default_value="${2:-}"
  shift 2
  local value=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --${flag}=*|-${flag}=*)
        value="${1#*=}"
        ;;
      --${flag}|-${flag})
        shift
        [[ $# -gt 0 ]] || die "--${flag} requires a value"
        value="$1"
        ;;
    esac
    shift || true
  done

  printf '%s\n' "${value:-${default_value}}"
}

start_bool_arg_value() {
  local flag="$1"
  local default_value="${2:-}"
  shift 2
  local value="${default_value}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --${flag}=*|-${flag}=*)
        value="${1#*=}"
        ;;
      --no${flag}|-no${flag})
        value="false"
        ;;
      --${flag}|-${flag})
        if [[ $# -gt 1 && "$2" != -* ]]; then
          shift
          value="$1"
        else
          value="true"
        fi
        ;;
    esac
    shift || true
  done

  printf '%s\n' "${value}"
}

start_gpu_mode_value() {
  start_arg_value "gpu_mode" "${CVD_GPU_DEFAULTS[gpu_mode]}" "$@"
}

merge_gfxstream_renderer_features() {
  local existing="$1"
  local required="$2"
  local result=""
  local feature
  local name
  local -a existing_features=()

  IFS=';' read -r -a existing_features <<<"${existing}"
  for feature in "${existing_features[@]}"; do
    [[ -n "${feature}" ]] || continue
    name="${feature%%:*}"
    case "${name}" in
      ExternalBlob|SystemBlob|VulkanAllocateHostVisibleAsUdmabuf|VulkanUseDedicatedAhbMemoryType)
        continue
        ;;
    esac
    result+="${result:+;}${feature}"
  done

  result+="${result:+;}${required}"
  printf '%s\n' "${result}"
}

append_or_merge_gpu_renderer_features() {
  local -n renderer_args_array="$1"
  local required="$2"
  local i
  local existing

  for i in "${!renderer_args_array[@]}"; do
    case "${renderer_args_array[${i}]}" in
      --gpu_renderer_features=*|-gpu_renderer_features=*)
        existing="${renderer_args_array[${i}]#*=}"
        renderer_args_array[${i}]="--gpu_renderer_features=$(merge_gfxstream_renderer_features "${existing}" "${required}")"
        return 0
        ;;
      --gpu_renderer_features|-gpu_renderer_features)
        (( i + 1 < ${#renderer_args_array[@]} )) || die "--gpu_renderer_features requires a value"
        existing="${renderer_args_array[$((i + 1))]}"
        renderer_args_array[$((i + 1))]="$(merge_gfxstream_renderer_features "${existing}" "${required}")"
        return 0
        ;;
    esac
  done

  renderer_args_array+=("--gpu_renderer_features=${required}")
}

gfxstream_context_types_include_vulkan() {
  local context_types="$1"
  local contexts="${context_types%%,*}"

  [[ ":${contexts}:" == *":gfxstream-vulkan:"* ]]
}

gfxstream_context_types_include_wsi_vk() {
  local context_types="$1"

  [[ ",${context_types}," == *",wsi=vk,"* ]]
}

append_gfxstream_wsi_vk() {
  local context_types="$1"

  if gfxstream_context_types_include_wsi_vk "${context_types}"; then
    printf '%s\n' "${context_types}"
  else
    printf '%s\n' "${context_types},wsi=vk"
  fi
}

merge_gpu_context_types_for_vulkan() {
  local -n context_args_array="$1"
  local default_context_types="$2"
  local require_wsi_vk="${3:-false}"
  local i
  local existing
  local merged

  for i in "${!context_args_array[@]}"; do
    case "${context_args_array[${i}]}" in
      --gpu_context_types=*|-gpu_context_types=*)
        existing="${context_args_array[${i}]#*=}"
        if [[ "${require_wsi_vk}" == "true" ]] \
            && gfxstream_context_types_include_vulkan "${existing}"; then
          merged="$(append_gfxstream_wsi_vk "${existing}")"
          context_args_array[${i}]="--gpu_context_types=${merged}"
        fi
        printf '%s\n' "${existing}"
        return 0
        ;;
      --gpu_context_types|-gpu_context_types)
        (( i + 1 < ${#context_args_array[@]} )) || die "--gpu_context_types requires a value"
        existing="${context_args_array[$((i + 1))]}"
        if [[ "${require_wsi_vk}" == "true" ]] \
            && gfxstream_context_types_include_vulkan "${existing}"; then
          merged="$(append_gfxstream_wsi_vk "${existing}")"
          context_args_array[$((i + 1))]="${merged}"
        fi
        printf '%s\n' "${existing}"
        return 0
        ;;
    esac
  done

  context_args_array+=("--gpu_context_types=${default_context_types}")
  printf '%s\n' "${default_context_types}"
}

append_gfxstream_vulkan_args() {
  local -n args_array="$1"
  shift
  local mode
  local selected_mode
  local gpu_mode
  local vulkan_decision
  local user_context_types
  local effective_context_types

  mode="$(normalize_gfxstream_vulkan_mode "${GFXSTREAM_VULKAN_MODE}")"
  GFXSTREAM_VULKAN_MODE="${mode}"

  gpu_mode="$(start_gpu_mode_value "$@")"
  CVD_GPU_MODE="${gpu_mode}"
  if [[ "${gpu_mode}" != "gfxstream" ]]; then
    CVD_GRAPHICS_DRIVER_MESSAGE="GPU is ${gpu_mode} (gfxstream-vulkan=${mode} ignored)"
    log "gfxstream-vulkan=${mode} has no effect with gpu_mode=${gpu_mode}"
    return 0
  fi

  if user_supplied_flag "gpu_context_types" "$@"; then
    user_context_types="$(merge_gpu_context_types_for_vulkan args_array \
      "${GFXSTREAM_VULKAN_CONTEXT_TYPES_WITH_WSI}" \
      "$([[ "${mode}" == "on" ]] && echo true || echo false)")"
    effective_context_types="$(start_arg_value "gpu_context_types" "${user_context_types}" "${args_array[@]}")"
    CVD_GRAPHICS_DRIVER_MESSAGE="gfxstream (user gpu_context_types; gfxstream-vulkan=${mode})"
    log "using user supplied gpu_context_types=${effective_context_types}; gfxstream-vulkan=${mode}"
    if gfxstream_context_types_include_vulkan "${effective_context_types}" \
        && is_apple_silicon_16k_host; then
      append_or_merge_gpu_renderer_features \
        args_array "${GFXSTREAM_APPLE_16K_VULKAN_RENDERER_FEATURES}"
      log "Apple Silicon 16K host: routing host-visible Vulkan memory via udmabuf dma-buf"
    fi
    return 0
  fi

  selected_mode="${mode}"
  vulkan_decision="gfxstream-vulkan=${mode}"
  if [[ "${selected_mode}" == "auto" ]]; then
    if is_apple_silicon_16k_host; then
      selected_mode="off"
      vulkan_decision="gfxstream-vulkan=auto -> off (Apple Silicon 16K host)"
    elif primary_vulkan_device_is_llvmpipe; then
      selected_mode="off"
      vulkan_decision="gfxstream-vulkan=auto -> off (primary Vulkan device is llvmpipe)"
    else
      CVD_GRAPHICS_DRIVER_MESSAGE="gfxstream (Defaults; vulkan=auto)"
      log "gfxstream-vulkan=auto; leaving Cuttlefish gfxstream defaults"
      return 0
    fi
  fi

  case "${selected_mode}" in
    off)
      args_array+=("--gpu_context_types=${GFXSTREAM_GLES_CONTEXT_TYPES}")
      CVD_GRAPHICS_DRIVER_MESSAGE="gfxstream (GLES-only)"
      log "${vulkan_decision}; context-types=${GFXSTREAM_GLES_CONTEXT_TYPES}"
      ;;
    on)
      args_array+=("--gpu_context_types=${GFXSTREAM_VULKAN_CONTEXT_TYPES_WITH_WSI}")
      CVD_GRAPHICS_DRIVER_MESSAGE="gfxstream (GLES+Vulkan; ${vulkan_decision})"
      log "${vulkan_decision}; context-types=${GFXSTREAM_VULKAN_CONTEXT_TYPES_WITH_WSI}"
      if is_apple_silicon_16k_host; then
        append_or_merge_gpu_renderer_features \
          args_array "${GFXSTREAM_APPLE_16K_VULKAN_RENDERER_FEATURES}"
        log "Apple Silicon 16K host: routing host-visible Vulkan memory via udmabuf dma-buf"
      fi
      ;;
  esac
}

require_executable() {
  local path="$1"
  local label="$2"
  [[ -x "${path}" ]] || die "${label} not found or not executable: ${path}"
}

instance_has_userdata_state() {
  [[ -e "${CVD_INSTANCE_DIR}/overlay.img" || -e "${CVD_INSTANCE_DIR}/userdata.img" ]]
}

composite_disk_rebuild_reason() {
  local name="$1"
  local disk="${CVD_INSTANCE_DIR}/${name}.img"
  local config="${CVD_INSTANCE_DIR}/${name}_disk_config.txt"
  local component

  if [[ ! -e "${disk}" ]]; then
    printf '%s\n' "${name}.img is missing"
    return 0
  fi

  if [[ ! -e "${config}" ]]; then
    printf '%s\n' "${name}_disk_config.txt is missing"
    return 0
  fi

  while IFS= read -r component; do
    [[ -n "${component}" ]] || continue
    [[ "${component}" != "crosvm" ]] || continue
    [[ -e "${component}" ]] || continue

    if [[ "${component}" -nt "${disk}" ]]; then
      printf '%s\n' "${component} is newer than ${name}.img"
      return 0
    fi
  done < "${config}"

  return 1
}

is_generated_os_component() {
  [[ "$1" == "${CVD_INSTANCE_DIR}/metadata" || "$1" == "${CVD_INSTANCE_DIR}/misc" ]]
}

refresh_generated_os_component_mtimes() {
  local disk="${CVD_INSTANCE_DIR}/os_composite.img"
  local config="${CVD_INSTANCE_DIR}/os_composite_disk_config.txt"
  local overlay="${CVD_INSTANCE_DIR}/overlay.img"
  local component
  local path
  local needs_refresh="false"

  [[ -e "${overlay}" && -e "${disk}" && -e "${config}" ]] || return 0

  while IFS= read -r component; do
    [[ -n "${component}" ]] || continue
    [[ "${component}" != "crosvm" ]] || continue
    [[ -e "${component}" ]] || continue
    [[ "${component}" -nt "${disk}" ]] || continue

    if ! is_generated_os_component "${component}"; then
      return 0
    fi

    needs_refresh="true"
  done < "${config}"

  [[ "${needs_refresh}" == "true" ]] || return 0

  for path in \
    "${disk}" \
    "${CVD_INSTANCE_DIR}/os_composite_gpt_header.img" \
    "${CVD_INSTANCE_DIR}/os_composite_gpt_footer.img"; do
    [[ -e "${path}" ]] && touch "${path}" 2>/dev/null || true
  done
  touch "${overlay}" 2>/dev/null || true
}

protect_overlay_resume() {
  local reason

  [[ -e "${CVD_INSTANCE_DIR}/overlay.img" ]] || return 0

  refresh_generated_os_component_mtimes

  if reason="$(composite_disk_rebuild_reason os_composite)"; then
    respond_console "Refusing to start because Cuttlefish would rebuild the OS disk and discard VM data."
    respond_console "Reason: ${reason}"
    respond_console "Run '${SCRIPT_NAME} reset' if you want to discard the current VM data."
    die "refusing to discard overlay.img: ${reason}"
  fi

  if [[ -e "${CVD_INSTANCE_DIR}/ap_composite.img" ]] \
      && reason="$(composite_disk_rebuild_reason ap_composite)"; then
    respond_console "Refusing to start because Cuttlefish would rebuild the AP disk and discard VM data."
    respond_console "Reason: ${reason}"
    respond_console "Run '${SCRIPT_NAME} reset' if you want to discard the current VM data."
    die "refusing to discard overlay.img: ${reason}"
  fi
}

append_data_storage_args() {
  local -n args_array="$1"
  shift
  local requested_data_gb="${DATA_GB:-}"
  local data_gb
  local data_mb
  local has_existing_userdata_state="false"
  local explicit_data_policy="false"
  local explicit_data_size="false"

  if user_supplied_flag "data_policy" "$@"; then
    explicit_data_policy="true"
  fi
  if user_supplied_flag "blank_data_image_mb" "$@"; then
    explicit_data_size="true"
  fi

  if instance_has_userdata_state; then
    has_existing_userdata_state="true"
  fi

  if [[ "${explicit_data_policy}" != "true" && "${has_existing_userdata_state}" == "true" ]]; then
    if [[ -n "${requested_data_gb}" ]]; then
      CVD_DATA_STORAGE_MESSAGE="Ignored userdata resize; you must reset the instance first: 'ika reset'"
      log "DATA_GB=${requested_data_gb} requested, but existing userdata state is present; run '${SCRIPT_NAME} reset' before the next start to apply it."
    fi
    return 0
  fi

  data_gb="$(normalize_data_gb "${requested_data_gb:-${DEFAULT_DATA_GB}}")"
  data_mb="$(data_gb_to_mib "${data_gb}")"

  if [[ "${explicit_data_policy}" != "true" ]]; then
    args_array+=("--data_policy=always_create")
  fi

  if [[ "${explicit_data_size}" != "true" ]]; then
    args_array+=("--blank_data_image_mb=${data_mb}")
  fi

  CVD_NEWLY_PROVISIONED="true"

  if [[ -n "${requested_data_gb}" ]]; then
    CVD_DATA_STORAGE_MESSAGE="Provisioning ${data_gb} GB userdata..."
    log "fresh userdata target: ${data_mb} MiB"
  fi
}

apply_default_args() {
  local -n config_map="$1"
  local -n args_array="$2"
  shift 2
  local key value

  for key in "${!config_map[@]}"; do
    if ! user_supplied_flag "${key}" "$@"; then
      value="${config_map[${key}]}"
      # Handle special case for report_anonymous_usage_stats which uses single dash
      if [[ "${key}" == "report_anonymous_usage_stats" ]]; then
        args_array+=("-${key}=${value}")
      else
        args_array+=("--${key}=${value}")
      fi
    fi
  done
}

apply_start_default_args() {
  local args_array_name="$1"
  shift
  local config_map

  for config_map in "${CVD_DEFAULT_ARG_MAPS[@]}"; do
    apply_default_args "${config_map}" "${args_array_name}" "$@"
  done
}

append_webrtc_audio_args() {
  local -n args_array="$1"
  shift
  local start_webrtc

  start_webrtc="$(start_bool_arg_value "start_webrtc" "${CVD_LAUNCHER_DEFAULTS[start_webrtc]}" "$@")"

  case "${start_webrtc}" in
    false|False|FALSE|0|no|No|NO|off|Off|OFF)
      if ! user_supplied_flag "enable_audio" "$@"; then
        args_array+=("--enable_audio=false")
        log "start_webrtc=false; disabling Cuttlefish audio server"
      fi
      ;;
  esac
}

append_host_timezone_arg() {
  local -n args_array="$1"
  local tz

  tz="$(readlink /etc/localtime 2>/dev/null | sed 's|.*/zoneinfo/||')"
  [[ -n "${tz}" ]] || return 0

  args_array+=("--extra_bootconfig_args=androidboot.timezone=\"${tz}\" androidboot.cuttlefish_service_bluetooth_checker=false")
  log "timezone: ${tz}"
}

append_cvd_env_args() {
  local -n env_args_ref="$1"
  local config_path="${2:-}"

  env_args_ref+=(
    "HOME=${CVD_HOME_DIR}"
    "TMPDIR=${CVD_TMP_DIR}"
    "ANDROID_HOST_OUT=${CVD_HOST_OUT}"
    "ANDROID_SOONG_HOST_OUT=${CVD_HOST_OUT}"
    "ANDROID_PRODUCT_OUT=${CVD_PRODUCT_OUT}"
  )

  if [[ -n "${config_path}" ]]; then
    env_args_ref+=("CUTTLEFISH_CONFIG_FILE=${config_path}")
  fi
}

run_with_cvd_env() {
  local config_path=""
  local -a env_args=(env)

  if [[ "${1:-}" == "--config" ]]; then
    config_path="${2:-}"
    shift 2
  fi

  append_cvd_env_args env_args "${config_path}"
  "${env_args[@]}" "$@"
}

run_stop_helper() {
  local -a statuses

  set +e
  set +o pipefail
  run_with_cvd_env "$@" 2>&1 | grep -v -Fx "Requesting stop"
  statuses=("${PIPESTATUS[@]}")
  set -o pipefail
  set -e

  return "${statuses[0]}"
}

has_session_group() {
  id -nG | tr ' ' '\n' | grep -Fxq "$1"
}

has_configured_group() {
  id -nG "${USER}" | tr ' ' '\n' | grep -Fxq "$1"
}

check_required_groups() {
  local -a required_groups=(kvm video render cvdnetwork)
  local -a missing_groups=()
  local -a inactive_groups=()
  local -a add_groups=()
  local group

  for group in "${required_groups[@]}"; do
    if getent group "${group}" >/dev/null 2>&1 && ! has_session_group "${group}"; then
      missing_groups+=("${group}")
      if has_configured_group "${group}"; then
        inactive_groups+=("${group}")
      else
        add_groups+=("${group}")
      fi
    fi
  done

  if [[ "${#missing_groups[@]}" -eq 0 ]]; then
    return 0
  fi

  cat <<EOF
[${SCRIPT_NAME}] error: current shell is missing required groups.

Active groups:
  $(id -nG)

Missing groups:
  ${missing_groups[*]}

EOF

  if [[ "${#add_groups[@]}" -gt 0 ]]; then
    cat <<EOF
To add the missing account membership:
  pkexec /usr/libexec/cuttlefish/cuttlefish-add-user-to-groups

EOF
  fi

  if [[ "${#inactive_groups[@]}" -gt 0 ]]; then
    cat <<EOF
Configured on the account but not active in this login session:
  ${inactive_groups[*]}

EOF
  fi

  cat <<EOF

Log out fully and back in after updating group membership.
EOF
  exit 1
}

resolve_adb_serial() {
  local adb_ip_and_port=""

  if [[ -f "${CVD_CONFIG_PATH}" ]]; then
    adb_ip_and_port="$(grep -oE '"adb_ip_and_port"[[:space:]]*:[[:space:]]*"[^"]+"' "${CVD_CONFIG_PATH}" | head -n1 | sed -E 's/.*"([^"]+)"$/\1/' || true)"
  fi

  case "${adb_ip_and_port:-127.0.0.1:6520}" in
    0.0.0.0:*)
      printf '127.0.0.1:%s\n' "${adb_ip_and_port#*:}"
      ;;
    '[::]':*)
      printf '127.0.0.1:%s\n' "${adb_ip_and_port##*:}"
      ;;
    *)
      printf '%s\n' "${adb_ip_and_port:-127.0.0.1:6520}"
      ;;
  esac
}

resolve_cuttlefish_frames_socket() {
  local frame_sock_path=""
  local socket_path

  if [[ -f "${CVD_CONFIG_PATH}" ]]; then
    frame_sock_path="$(grep -oE '"frame_sock_path"[[:space:]]*:[[:space:]]*"[^"]+"' "${CVD_CONFIG_PATH}" | head -n1 | sed -E 's/.*"([^"]+)"$/\1/' || true)"
  fi

  if [[ -n "${frame_sock_path}" ]]; then
    socket_path="$(dirname "${frame_sock_path}")/ika_frames.sock"
  else
    socket_path="/tmp/cf_avd_${UID}/cvd-1/internal/ika_frames.sock"
  fi

  printf '%s\n' "${socket_path}"
}

has_live_cvd_processes() {
  pgrep -f "${CVD_PROCESS_REGEX}" >/dev/null 2>&1
}

stop_dnsmasq() {
  local pid_file
  for pid_file in /var/tmp/cvd/cuttlefish-dnsmasq-*.pid /var/run/cuttlefish-dnsmasq-*.pid; do
    [[ -f "${pid_file}" ]] || continue
    kill "$(cat "${pid_file}")" 2>/dev/null || true
    rm -f "${pid_file}"
    rm -f "${pid_file%.pid}.leases"
  done
  pkill -f 'dnsmasq.*cvd-' 2>/dev/null || true
}

cleanup_user_processes() {
  local -a pids=()
  local pid

  while read -r pid; do
    [[ -n "${pid}" ]] || continue
    [[ "${pid}" == "$$" ]] && continue
    pids+=("${pid}")
  done < <(pgrep -f "${CVD_PROCESS_REGEX}" || true)

  if [[ "${#pids[@]}" -eq 0 ]]; then
    return 0
  fi

  mapfile -t pids < <(printf '%s\n' "${pids[@]}" | sort -u)
  log "stopping leftover Cuttlefish processes: ${pids[*]}"
  kill "${pids[@]}" 2>/dev/null || true
  sleep 1
  kill -9 "${pids[@]}" 2>/dev/null || true
}

within_deadline() {
  local deadline="$1"
  [[ "${deadline}" -eq 0 || ${SECONDS} -lt ${deadline} ]]
}

make_deadline() {
  local timeout_sec="$1"
  if [[ "${timeout_sec}" -gt 0 ]]; then
    printf '%s\n' "$((SECONDS + timeout_sec))"
  else
    printf '0\n'
  fi
}

adb_boot_completed() {
  local adb_serial="$1"
  local adb_bin
  local boot_completed

  if [[ -x "${CVD_ADB_BIN}" ]]; then
    adb_bin="${CVD_ADB_BIN}"
  else
    adb_bin="$(command -v adb || true)"
  fi
  [[ -n "${adb_bin}" ]] || return 1

  boot_completed="$("${adb_bin}" -s "${adb_serial}" shell getprop sys.boot_completed 2>/dev/null | tr -d '\r' || true)"
  [[ "${boot_completed}" == "1" ]]
}

sync_android_filesystems() {
  local adb_serial="$1"

  [[ -x "${CVD_ADB_BIN}" ]] || return 0

  if ! "${CVD_ADB_BIN}" -s "${adb_serial}" shell sync >/dev/null 2>&1; then
    log "Android filesystem sync failed or device is unavailable; continuing stop."
  fi
}

wait_for_boot() {
  local launcher_log="$1"
  local deadline="$2"
  local min_mtime="${3:-0}"
  local adb_serial="$4"
  local crosvm_command_reported="false"

  while within_deadline "${deadline}"; do
    if [[ -f "${launcher_log}" ]]; then
      local log_mtime
      log_mtime="$(stat -c '%Y' "${launcher_log}" 2>/dev/null || echo 0)"
      if [[ "${crosvm_command_reported}" != "true" ]]; then
        if maybe_respond_crosvm_command "${launcher_log}" "${min_mtime}"; then
          crosvm_command_reported="true"
        fi
      fi
    fi
    if adb_boot_completed "${adb_serial}"; then
      return 0
    fi
    if ! has_live_cvd_processes; then
      return 1
    fi
    sleep 0.5
  done

  return 1
}

ensure_chromium_before_scrcpy() {
  local adb_serial="$1"

  if [[ "${CVD_NEWLY_PROVISIONED}" != "true" ]]; then
    return 0
  fi

  if [[ ! -x "${PACKAGED_GETCHROMIUM_BIN}" ]]; then
    log "${PACKAGED_GETCHROMIUM_BIN} is unavailable; continuing to scrcpy."
    return 0
  fi

  if ANDROID_SERIAL="${adb_serial}" IKA_CHROMIUM_STAMP="${CHROMIUM_INSTALL_STAMP}" "${PACKAGED_GETCHROMIUM_BIN}" >&3 2>&3; then
    mkdir -p "$(dirname "${CHROMIUM_INSTALL_STAMP}")"
    : > "${CHROMIUM_INSTALL_STAMP}"
    log "getchromium completed."
  else
    log "getchromium failed; continuing to scrcpy."
  fi
}

start_scrcpy_with_retries() {
  local adb_serial="$1"
  local fullscreen_mode="${2:-false}"
  local game_mode="${3:-false}"
  local attempt=1
  local max_attempts=5
  local cuttlefish_frames_socket
  local scrcpy_log="${SCRCPY_LOG_FILE}"
  local host_core_list
  local scrcpy_lock_file="${CVD_HOME_DIR}/scrcpy-launch.lock"
  local scrcpy_lock_fd=""
  local scrcpy_window_size
  local scrcpy_window_width
  local scrcpy_window_height
  local -a scrcpy_env=()
  local -a scrcpy_extra_args=()
  local -a scrcpy_cmd=(
    "${SCRCPY_BIN}"
    -s "${adb_serial}"
  )

  exec {scrcpy_lock_fd}>"${scrcpy_lock_file}"
  if ! flock "${scrcpy_lock_fd}"; then
    log "unable to acquire scrcpy launch lock: ${scrcpy_lock_file}"
    return 1
  fi

  stop_startup_packaged_scrcpy

  scrcpy_window_size="$(default_scrcpy_window_size)"
  if [[ "${scrcpy_window_size}" =~ ^([0-9]+)x([0-9]+)$ ]]; then
    scrcpy_window_width="${BASH_REMATCH[1]}"
    scrcpy_window_height="${BASH_REMATCH[2]}"
  else
    scrcpy_window_width=1280
    scrcpy_window_height=720
  fi

  if [[ -n "${SCRCPY_DPI}" ]]; then
    scrcpy_cmd+=("--dpi=${SCRCPY_DPI}")
  fi
  scrcpy_cmd+=(
    --mouse-bind=+hsn:b+++
    --force-adb-forward
    --render-driver=opengl
    --window-borderless
    --window-width="${scrcpy_window_width}"
    --window-height="${scrcpy_window_height}"
    --audio-codec=raw
  )

  # Game mode uses UHID for all input devices; normal mode keeps text-friendly
  # SDK keyboard injection.
  if [[ "${game_mode}" == "true" ]]; then
    log "scrcpy game mode: UHID gamepad, keyboard, and mouse"
    scrcpy_cmd+=(
      --gamepad=uhid
      --keyboard=uhid
      --mouse=uhid
    )
  else
    scrcpy_cmd+=(
      --keyboard=sdk
      --prefer-text
    )
  fi

  cuttlefish_frames_socket="$(resolve_cuttlefish_frames_socket)"
  scrcpy_cmd+=(--cuttlefish-frames-socket="${cuttlefish_frames_socket}")
  log "scrcpy video source: raw Cuttlefish frames (${cuttlefish_frames_socket})"

  if [[ -n "${IKA_SCRCPY:-}" ]]; then
    read -r -a scrcpy_extra_args <<<"${IKA_SCRCPY}"
    if [[ "${#scrcpy_extra_args[@]}" -gt 0 ]]; then
      log "using extra scrcpy args: $(shell_join "${scrcpy_extra_args[@]}")"
      scrcpy_cmd+=("${scrcpy_extra_args[@]}")
    fi
  fi

  if [[ -d "${SCRCPY_ICON_DIR_DEFAULT}" ]]; then
    scrcpy_env+=("SCRCPY_ICON_DIR=${SCRCPY_ICON_DIR_DEFAULT}")
  fi

  if [[ -x "${CVD_CLI_BIN}" ]]; then
    scrcpy_env+=("IKA_CVD_BIN=${CVD_CLI_BIN}")
  fi

  # scrcpy spawns `adb` to push the server jar and open the shell. Point it
  # at the cuttlefish-bundled adb explicitly so it doesn't rely on PATH —
  # on a stock Asahi system there's no /usr/bin/adb, and even where there
  # is one we want the cuttlefish version that's known to match the rest
  # of the cvd-host_package.
  local packaged_adb="${PACKAGED_CVD_HOST_OUT}/bin/adb"
  if [[ -x "${packaged_adb}" ]]; then
    scrcpy_env+=("ADB=${packaged_adb}")
  fi

  if [[ -n "${SCRCPY_SERVER_PATH_OVERRIDE}" && -f "${SCRCPY_SERVER_PATH_OVERRIDE}" ]]; then
    scrcpy_env+=("SCRCPY_SERVER_PATH=${SCRCPY_SERVER_PATH_OVERRIDE}")
  fi

  if [[ "${#scrcpy_env[@]}" -gt 0 ]]; then
    scrcpy_cmd=(
      env
      "${scrcpy_env[@]}"
      "${scrcpy_cmd[@]}"
    )
  fi

  host_core_list="$(reserved_host_core_list)"
  if [[ -n "${host_core_list}" ]] && command -v taskset >/dev/null 2>&1; then
    log "pinning direct console to host performance cores: ${host_core_list}"
    scrcpy_cmd=(taskset -c "${host_core_list}" "${scrcpy_cmd[@]}")
  fi

  mkdir -p "$(dirname "${scrcpy_log}")"
  : > "${scrcpy_log}"

  ensure_chromium_before_scrcpy "${adb_serial}"

  while [[ "${attempt}" -le "${max_attempts}" ]]; do
    log "starting scrcpy for ${adb_serial} (attempt ${attempt})"
    if [[ "${fullscreen_mode}" == "true" ]]; then
      setsid --fork "${scrcpy_cmd[@]}" --fullscreen </dev/null >>"${scrcpy_log}" 2>&1 3>&- &
    else
      setsid --fork "${scrcpy_cmd[@]}" </dev/null >>"${scrcpy_log}" 2>&1 3>&- &
    fi
    disown || true

    sleep 1.5
    if has_packaged_scrcpy; then
      return 0
    fi

    log "scrcpy exited quickly; retrying."
    attempt=$((attempt + 1))
    if [[ "${attempt}" -le "${max_attempts}" ]]; then
      sleep 1
    fi
  done

  log "unable to keep scrcpy running after ${max_attempts} attempts."
  return 1
}

schedule_scrcpy_when_launcher_ready() {
  local adb_serial="$1"
  local fullscreen_mode="${2:-false}"
  local game_mode="${3:-false}"

  (
    while has_live_cvd_processes; do
      if adb_boot_completed "${adb_serial}"; then
        break
      fi
      sleep 0.5
    done

    if ! has_live_cvd_processes; then
      log "deferred scrcpy watcher stopped because Cuttlefish exited before sys.boot_completed=1."
      exit 0
    fi
    start_scrcpy_with_retries "${adb_serial}" "${fullscreen_mode}" "${game_mode}" || true
  ) &

  disown || true
  log "scheduled scrcpy launch when adb reports sys.boot_completed=1"
}

maybe_start_scrcpy() {
  local adb_serial="$1"
  local fullscreen_mode="${2:-false}"
  local game_mode="${3:-false}"

  if [[ ! -x "${SCRCPY_BIN}" ]]; then
    log "scrcpy not found at ${SCRCPY_BIN}; skipping client launch."
    return 0
  fi

  if adb_boot_completed "${adb_serial}"; then
    log "adb reports sys.boot_completed=1; starting scrcpy immediately."
    start_scrcpy_with_retries "${adb_serial}" "${fullscreen_mode}" "${game_mode}" || true
    return 0
  fi

  log "adb has not reported sys.boot_completed=1; deferring scrcpy launch."
  schedule_scrcpy_when_launcher_ready "${adb_serial}" "${fullscreen_mode}" "${game_mode}"
  return 0
}

log_start_context() {
  local launcher_log="$1"
  shift
  local scrcpy_dpi
  local cpu_count
  local memory_mb
  local start_message
  scrcpy_dpi="${SCRCPY_DPI:-unknown}"
  cpu_count="$(start_arg_value "cpus" "${CVD_COMPUTE_DEFAULTS[cpus]}" "$@")"
  memory_mb="$(start_arg_value "memory_mb" "${CVD_COMPUTE_DEFAULTS[memory_mb]}" "$@")"

  start_message="Starting Cuttlefish: ${cpu_count} Cores, ${memory_mb} MB"
  if [[ -n "${CVD_GRAPHICS_DRIVER_MESSAGE}" ]]; then
    start_message+=", ${CVD_GRAPHICS_DRIVER_MESSAGE}"
  fi
  start_message+=" ${scrcpy_dpi} DPI"
  log "${start_message}"
  printf '%s\n' "${start_message}" >&3
  if [[ -n "${CVD_DATA_STORAGE_MESSAGE}" ]]; then
    log "${CVD_DATA_STORAGE_MESSAGE}"
    printf '%s\n' "${CVD_DATA_STORAGE_MESSAGE}" >&3
  fi
  log "HOME=${CVD_HOME_DIR}"
  log "TMPDIR=${CVD_TMP_DIR}"
  log "ANDROID_HOST_OUT=${CVD_HOST_OUT}"
  log "ANDROID_PRODUCT_OUT=${CVD_PRODUCT_OUT}"
  log "gpu_mode=${CVD_GPU_MODE}"
  log "launcher_log=${launcher_log}"
  emit_launch_command "$@"
}

start_cvd() {
  local fullscreen_mode="${1:-false}"
  local game_mode="${2:-false}"
  shift 2 || true
  local -a args=()
  local launcher_log
  local adb_serial
  local boot_deadline
  local launcher_pid
  local start_epoch
  local scrcpy_dpi
  local -a cvd_env_args=(env)

  require_executable "${CVD_BIN}" "cvd launcher"
  check_required_groups
  ensure_open_file_limit
  launcher_log="${CVD_LAUNCHER_LOG}"
  adb_serial="$(resolve_adb_serial)"
  start_epoch="$(date +%s)"
  split_start_args args scrcpy_dpi "$@"
  SCRCPY_DPI="${scrcpy_dpi}"

  if has_live_cvd_processes; then
    log "Cuttlefish is already running under ${CVD_HOME_DIR}"
    if [[ -n "${DATA_GB:-}" ]]; then
      respond_console "Ignored userdata resize; you must reset the instance first: 'ika reset'"
    else
      respond_console "Instance already running, local console will be restarted"
    fi
    respond "Android virtual device running"
    maybe_start_scrcpy "${adb_serial}" "${fullscreen_mode}" "${game_mode}" || true
    return 0
  fi

  protect_overlay_resume

  apply_start_default_args args "$@"
  append_webrtc_audio_args args "$@"
  append_data_storage_args args "$@"
  append_arm64_kernel_page_args args "$@"
  append_gfxstream_vulkan_args args "$@"
  append_default_display_arg args "${scrcpy_dpi}" "$@"
  append_host_timezone_arg args
  append_cvd_env_args cvd_env_args

  log_start_context "${launcher_log}" "${args[@]}"

  (
    cd "${CVD_PRODUCT_OUT}"
    exec 3>&-
    exec "${cvd_env_args[@]}" "${CVD_BIN}" "${args[@]}"
  ) &
  launcher_pid="$!"
  disown "${launcher_pid}" || true

  log "launcher pid: ${launcher_pid}"

  boot_deadline="$(make_deadline "${CVD_BOOT_TIMEOUT_SEC}")"
  if ! wait_for_boot "${launcher_log}" "${boot_deadline}" "${start_epoch}" "${adb_serial}"; then
    if [[ -f "${launcher_log}" ]]; then
      tail -n 80 "${launcher_log}" >&2 || true
    fi
    die "Cuttlefish did not reach boot completion"
  fi

  log "boot completed after seeing: adb sys.boot_completed=1"
  respond "Android virtual device running"
  maybe_start_scrcpy "${adb_serial}" "${fullscreen_mode}" "${game_mode}" || true

}

stop_cvd_internal() {
  local clear_instance_dirs="${1:-false}"
  shift || true
  local adb_serial
  local stop_ok="false"
  local -a run_with_args=()
  local -a stop_args=()

  if [[ "${clear_instance_dirs}" == "true" ]]; then
    stop_args+=("--clear_instance_dirs")
  fi
  stop_args+=("$@")

  require_executable "${CVD_STOP_BIN}" "cvd stop helper"

  if [[ "${clear_instance_dirs}" != "true" ]] && has_live_cvd_processes; then
    adb_serial="$(resolve_adb_serial)"
    sync_android_filesystems "${adb_serial}"
  fi

  if [[ -f "${CVD_CONFIG_PATH}" ]]; then
    run_with_args+=(--config "${CVD_CONFIG_PATH}")
  fi

  if run_stop_helper "${run_with_args[@]}" "${CVD_STOP_BIN}" "${stop_args[@]}"; then
    stop_ok="true"
  else
    log "primary stop helper returned non-zero"
  fi

  if [[ "${stop_ok}" != "true" ]]; then
    log "retrying stop via $(basename "${CVD_CLI_BIN}") stop"
    run_with_cvd_env "${CVD_CLI_BIN}" stop "${stop_args[@]}" && stop_ok="true" || true
  fi

  if [[ "${clear_instance_dirs}" == "true" ]]; then
    run_with_cvd_env "${CVD_CLI_BIN}" clear >/dev/null 2>&1 || true
    rm -f "${CHROMIUM_INSTALL_STAMP}"
  fi

  stop_dnsmasq
  cleanup_user_processes

  if has_live_cvd_processes; then
    die "Cuttlefish processes are still running after stop attempt"
  fi

  if [[ "${stop_ok}" != "true" ]]; then
    log "stop helper reported no active device; no live Cuttlefish processes remain"
  fi

}

exec_start_command() {
  local fullscreen_mode="$1"
  local game_mode="$2"
  shift 2

  if [[ "${game_mode}" == "true" ]]; then
    exec "$0" start --game "$@"
  elif [[ "${fullscreen_mode}" == "true" ]]; then
    exec "$0" start --fullscreen "$@"
  fi

  exec "$0" start "$@"
}

main() {
  local command="${1:-help}"
  local fullscreen_mode
  local game_mode
  local -a start_args

  case "${command}" in
    start)
      CONSOLE_FAILURE_MESSAGE="Startup Failed."
      stop_startup_packaged_scrcpy
      redirect_start_logs
      shift
      start_args=()
      parse_start_options fullscreen_mode game_mode start_args "$@"
      run_timed_operation "started" start_cvd "${fullscreen_mode}" "${game_mode}" "${start_args[@]}"
      ;;
    stop)
      shift
      stop_cvd_internal false "$@"
      ;;
    reset)
      shift
      confirm_reset || exit 1
      stop_cvd_internal true "$@"
      ;;
    restart)
      shift
      start_args=()
      parse_start_options fullscreen_mode game_mode start_args "$@"
      protect_overlay_resume
      stop_cvd_internal false
      sleep 0.5
      exec_start_command "${fullscreen_mode}" "${game_mode}" "${start_args[@]}"
      ;;
    status)
      if has_live_cvd_processes; then
        respond "Android virtual device running."
      else
        respond "Android virtual device not running."
      fi
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
