# Maintainer: DesktopECHO <build@desktopecho.com>
# Mirrors base/rpm/cuttlefish-scrcpy.spec. The scrcpy-server APK is built
# beforehand and packaged in the source tarball at scrcpy/scrcpy-server.

pkgbase=ika-scrcpy
pkgname=(ika-scrcpy)
pkgver=3.3.4
pkgrel=6
pkgdesc='scrcpy Android screen mirroring tool for Cuttlefish'
arch=(x86_64 aarch64)
url='https://github.com/Genymobile/scrcpy'
license=(Apache-2.0)
makedepends=(ffmpeg gcc icu libusb meson ninja pkgconf sdl3 vulkan-headers)
options=(!debug)
_srcver=1.55.0
source=("android-cuttlefish-${_srcver}.tar.gz")
sha256sums=('SKIP')

_srcroot="android-cuttlefish-${_srcver}"

build() {
  cd "${srcdir}/${_srcroot}"
  meson setup scrcpy _build_scrcpy \
      --buildtype=release \
      --prefix=/usr/lib/cuttlefish-common \
      --bindir=bin \
      -Dprebuilt_server=scrcpy-server \
      -Dcompile_server=true
  meson compile -C _build_scrcpy
}

package_ika-scrcpy() {
  depends=(ika-base ffmpeg libusb sdl3 wayland-utils)

  cd "${srcdir}/${_srcroot}"
  DESTDIR="${pkgdir}" meson install -C _build_scrcpy

  install -d "${pkgdir}/usr/share/applications"
  install -d "${pkgdir}/usr/share/icons/hicolor/256x256/apps"

  install -m 0644 \
    "${pkgdir}/usr/lib/cuttlefish-common/share/applications/scrcpy.desktop" \
    "${pkgdir}/usr/share/applications/ika-scrcpy.desktop"
  install -m 0644 \
    "${pkgdir}/usr/lib/cuttlefish-common/share/icons/hicolor/256x256/apps/scrcpy.png" \
    "${pkgdir}/usr/share/icons/hicolor/256x256/apps/ika-scrcpy.png"

  sed -i \
    -e 's#^Exec=.*#Exec=ika start#' \
    -e 's#^Name=.*#Name=Ika#' \
    -e 's#^Icon=.*#Icon=ika-scrcpy#' \
    -e '/^StartupNotify=/a StartupWMClass=scrcpy' \
    "${pkgdir}/usr/share/applications/ika-scrcpy.desktop"

  install -Dpm0644 scrcpy/LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
