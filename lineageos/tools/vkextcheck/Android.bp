package {
    default_applicable_licenses: ["Android-Apache-2.0"],
}

cc_binary {
    name: "vkextcheck",
    srcs: ["vkextcheck.cpp"],
    shared_libs: [
        "libvulkan",
    ],
    header_libs: [
        "vulkan_headers",
    ],
    cflags: [
        "-Wall",
        "-Werror",
    ],
    // Native x86_64 so it runs without arm64/Berberis translation.
    compile_multilib: "64",
}
