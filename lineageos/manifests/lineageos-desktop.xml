<?xml version="1.0" encoding="UTF-8"?>
<!--
    Track-tip configuration: revision="main" follows the ika repo's main
    branch. Tagged release builds should replace this with a specific commit
    SHA or tag (`revision="refs/tags/vX.Y"`) so the bundle is reproducible.
    The STRICT_RELEASE=1 gate in write_release_metadata.py fails the build if
    a release input is still floating.
-->
<manifest>
  <remote name="desktopecho" fetch="https://github.com/DesktopECHO" />
  <remote name="khronos" fetch="https://github.com" />

  <remove-project name="platform/external/vulkan-headers" />

  <project
      path="external/vulkan-headers"
      name="KhronosGroup/Vulkan-Headers"
      remote="khronos"
      revision="b5c8f996196ba4aa6d8f97e52b5d3b6e70f7e4e2"
      groups="pdk" />

  <project
      path="vendor/ika"
      name="ika"
      remote="desktopecho"
      revision="main">
    <linkfile src="lineageos" dest="vendor/lineage_desktop" />
  </project>
</manifest>
