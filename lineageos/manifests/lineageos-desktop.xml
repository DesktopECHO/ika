<?xml version="1.0" encoding="UTF-8"?>
<!--
    Track-tip configuration: revision="main" follows the ika repo's main
    branch. Tagged release builds should replace this with a specific commit
    SHA or tag (`revision="refs/tags/vX.Y"`) so the bundle is reproducible.
    The STRICT_RELEASE=1 gate in write_release_metadata.py fails the build if
    a release input is still floating.
-->
<manifest>
  <remote name="desktopecho" fetch="https://github.com/DesktopECHO" />
  <remote name="khronos" fetch="https://github.com" />

  <remove-project name="platform/external/vulkan-headers" />

  <!-- Mesa 26.1.5 is paired with generated Android/gfxstream build glue in
       external-mesa3d.patch. Some virtualization pins come from Android 17-era
       AOSP release heads, while minigbm remains on Android 16 QPR2; this mixed
       stack depends on the compatibility patches in this repository. Keep the
       Mesa source pin and integration patch together. Do not move any graphics
       pin without a boot, vulkaninfo, and Chromium/ANGLE screenshot verification
       pass on Apple Silicon. -->
  <extend-project
      name="platform/external/mesa3d"
      path="external/mesa3d"
      revision="6a02618ccf6c5651ecb9cccbde571eb61fd73592" />

  <!-- Keep both guest architectures and their virtual-device modules on the
       same Android 6.12 KMI release. This advances the guests from 6.12.38 to
       the 6.12.74 android16-6 maintenance build without changing kernel
       families. Google's matching x86-64 artifacts were published through the
       Android 17 release branch; immutable commits below carry the same Android
       16 kernel release and build ID as ARM64. -->
  <extend-project
      name="kernel/prebuilts/6.12/arm64"
      path="kernel/prebuilts/6.12/arm64"
      revision="318576752b27af3d328e6deb5e6aa29b08f762c9" />

  <extend-project
      name="kernel/prebuilts/common-modules/virtual-device/6.12/arm64"
      path="kernel/prebuilts/common-modules/virtual-device/6.12/arm64"
      revision="e6673fcbd05e63e6fcc2c2d2cf33246108b73b0c" />

  <extend-project
      name="kernel/prebuilts/6.12/x86-64"
      path="kernel/prebuilts/6.12/x86_64"
      revision="cb8e8ee3babf4a27b742f59dcb92f59cf186299c" />

  <extend-project
      name="kernel/prebuilts/common-modules/virtual-device/6.12/x86-64"
      path="kernel/prebuilts/common-modules/virtual-device/6.12/x86-64"
      revision="4463c45163d93baf9479744641a03961f58c1467" />

  <extend-project
      name="platform/external/minigbm"
      path="external/minigbm"
      revision="b7c93249f685222a524c51403719493cc114ff5d" />

  <extend-project
      name="device/google/cuttlefish"
      path="device/google/cuttlefish"
      revision="283645aacf6cdb56cc31a9362f54d412dbc132a1" />

  <extend-project
      name="device/google/cuttlefish_vmm"
      path="device/google/cuttlefish_vmm"
      revision="360473222a8700b6a935054b0c882cfbc2ba5701" />

  <extend-project
      name="device/google/cuttlefish_prebuilts"
      path="device/google/cuttlefish_prebuilts"
      revision="36f427b7c46682cfcdb2e61eee6893acbfb2a606" />

  <extend-project
      name="platform/external/crosvm"
      path="external/crosvm"
      revision="c7dd8d6950912fa5e6fde7ec2d1616e0ddc090f8" />

  <extend-project
      name="platform/hardware/google/gfxstream"
      path="hardware/google/gfxstream"
      revision="b46f0d4b4545def09bdf30651d4bf848b2ba0c34" />

  <extend-project
      name="platform/external/rust/rutabaga_gfx"
      path="external/rust/rutabaga_gfx"
      revision="1f181b0b3e4b821459f21fd9025cd4c408c4f9ec" />

  <project
      path="external/vulkan-headers"
      name="KhronosGroup/Vulkan-Headers"
      remote="khronos"
      revision="b5c8f996196ba4aa6d8f97e52b5d3b6e70f7e4e2"
      groups="pdk" />

  <project
      path="vendor/ika"
      name="ika"
      remote="desktopecho"
      revision="main">
    <linkfile src="lineageos" dest="vendor/lineage_desktop" />
  </project>
</manifest>
