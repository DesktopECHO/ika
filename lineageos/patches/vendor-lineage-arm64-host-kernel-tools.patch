Patch summary:
Use native ARM64 host kernel helper tools when building on ARM64 hosts.

The kernel build flags previously hard-coded the checked-in x86
kernel-build-tools lz4 and pahole binaries. That is fine for x86 hosts, but
fails on ARM64 Linux hosts when kbuild executes those tools. ARM64 hosts now use
the native system lz4 and pahole that the wrapper installs, while non-ARM64
hosts keep the existing prebuilt paths.

diff --git a/config/BoardConfigKernel.mk b/config/BoardConfigKernel.mk
index 3459674b..c03707c7 100644
--- a/config/BoardConfigKernel.mk
+++ b/config/BoardConfigKernel.mk
@@ -252,8 +252,16 @@ ifneq ($(TARGET_KERNEL_CLANG_COMPILE), false)
     endif
 endif
 
-# Pass prebuilt LZ4 path
-KERNEL_MAKE_FLAGS += LZ4=$(BUILD_TOP)/prebuilts/kernel-build-tools/linux-x86/bin/lz4
+ifeq ($(HOST_PREBUILT_TAG),linux-arm64)
+    KERNEL_HOST_LZ4 ?= /usr/bin/lz4
+    KERNEL_HOST_PAHOLE ?= /usr/bin/pahole
+else
+    KERNEL_HOST_LZ4 ?= $(BUILD_TOP)/prebuilts/kernel-build-tools/linux-x86/bin/lz4
+    KERNEL_HOST_PAHOLE ?= $(BUILD_TOP)/prebuilts/kernel-build-tools/linux-x86/bin/pahole
+endif
+
+# Pass LZ4 path
+KERNEL_MAKE_FLAGS += LZ4=$(KERNEL_HOST_LZ4)
 
 # Since Linux 4.16, flex and bison are required
 KERNEL_MAKE_FLAGS += LEX=$(BUILD_TOP)/prebuilts/build-tools/$(HOST_PREBUILT_TAG)/bin/flex
@@ -262,7 +270,7 @@ KERNEL_MAKE_FLAGS += M4=$(BUILD_TOP)/prebuilts/build-tools/$(HOST_PREBUILT_TAG)/
 TOOLS_PATH_OVERRIDE += BISON_PKGDATADIR=$(BUILD_TOP)/prebuilts/build-tools/common/bison
 
 # Since Linux 5.10, pahole is required
-KERNEL_MAKE_FLAGS += PAHOLE=$(BUILD_TOP)/prebuilts/kernel-build-tools/linux-x86/bin/pahole
+KERNEL_MAKE_FLAGS += PAHOLE=$(KERNEL_HOST_PAHOLE)
 
 # Rust bindgen wants matching Clang and libclang versions
 KERNEL_MAKE_FLAGS += LIBCLANG_PATH=$(TARGET_KERNEL_CLANG_PATH)/lib
