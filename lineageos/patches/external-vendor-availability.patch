Patch summary:
Expose external helper libraries needed by vendor-side desktop graphics and
camera modules. This only widens Soong availability for existing libraries:
Google Highway SIMD helpers, Skia color management, and XMP metadata support.

diff --git a/external/google-highway/Android.bp b/external/google-highway/Android.bp
index 56cc9bf5..421822cf 100644
--- a/external/google-highway/Android.bp
+++ b/external/google-highway/Android.bp
@@ -18,6 +18,7 @@ license {
 cc_library {
     name: "libhwy",
     host_supported: true,
+    vendor_available: true,
     sdk_version: "current",
     stl: "c++_shared",
     export_include_dirs: [
