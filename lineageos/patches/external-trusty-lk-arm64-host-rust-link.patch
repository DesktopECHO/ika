Patch summary:
Allow Trusty's host Rust linker arguments to be overridden by envsetup.
ARM64 Linux hosts use a GNU Rust host toolchain while Trusty's C/C++ host tools
use the ARM64 musl sysroot. Keeping the default as a fallback preserves x86 host
behavior, while envsetup can give Rust proc-macro links the Clang driver args
that match the Rust host stdlib.

diff --git a/engine.mk b/engine.mk
index 95b9a269..78a1540e 100644
--- a/engine.mk
+++ b/engine.mk
@@ -457,7 +457,7 @@ $(TOOLCHAIN_CONFIG): configheader
 
 GENERATED += $(TOOLCHAIN_CONFIG)
 
-GLOBAL_HOST_RUST_LINK_ARGS := -B $(CLANG_BINDIR) -B $(CLANG_HOST_SEARCHDIR) \
+GLOBAL_HOST_RUST_LINK_ARGS ?= -B $(CLANG_BINDIR) -B $(CLANG_HOST_SEARCHDIR) \
 	$(addprefix -L ,$(CLANG_HOST_LDDIRS)) --sysroot $(CLANG_HOST_SYSROOT) -fuse-ld=lld
 GLOBAL_HOST_RUSTFLAGS += -C linker="$(CLANG_BINDIR)/clang++" -C link-args="$(GLOBAL_HOST_RUST_LINK_ARGS)"
 GLOBAL_SHARED_RUSTFLAGS += -C linker="$(LD)"
