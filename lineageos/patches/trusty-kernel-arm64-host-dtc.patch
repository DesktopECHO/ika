Patch summary:
Allow Trusty DTB rules to use a host-provided device-tree compiler.
ARM64 host builds cannot execute the legacy x86_64 DTC prebuilt. Keep that
prebuilt as the default for existing x86 host builds, but let envsetup point the
DTB rules at Soong's host-built DTC when running on ARM64. Preserve the resolved
DTC path across repeated dtb.mk includes because the module cleanup at the end of
the file clears DTC_PREBUILT.

diff --git a/make/dtb.mk b/make/dtb.mk
index 78d3974..7b24198 100644
--- a/make/dtb.mk
+++ b/make/dtb.mk
@@ -39,7 +39,12 @@ MODULE_CPP_DTS := $(patsubst %.dts,$(BUILDDIR)/%.cpp.dts,$(MODULE_DTS))
 MODULE_DTB := $(patsubst %.cpp.dts,%.dtb,$(MODULE_CPP_DTS))
 MODULE_DTB_C := $(patsubst %.dtb,%.dtb.c,$(MODULE_DTB))
 
-DTC_PREBUILT := prebuilts/misc/linux-x86/dtc/dtc
+ifneq ($(strip $(DTC_PREBUILT)),)
+GLOBAL_DTC_PREBUILT := $(DTC_PREBUILT)
+endif
+ifeq ($(strip $(GLOBAL_DTC_PREBUILT)),)
+GLOBAL_DTC_PREBUILT := prebuilts/misc/linux-x86/dtc/dtc
+endif
 
 # Preprocess the .dts files
 $(MODULE_CPP_DTS): MODULE_DTS_INCLUDES := $(MODULE_DTS_INCLUDES)
@@ -50,7 +55,7 @@ $(MODULE_CPP_DTS): $(BUILDDIR)/%.cpp.dts: %.dts
 
 # Compile each .dts into a .dtb
 $(MODULE_DTB): MODULE_DTC_FLAGS := $(MODULE_DTC_FLAGS)
-$(MODULE_DTB): DTC_PREBUILT := $(DTC_PREBUILT)
+$(MODULE_DTB): DTC_PREBUILT := $(GLOBAL_DTC_PREBUILT)
 $(MODULE_DTB): %.dtb: %.cpp.dts
 	@$(MKDIR)
 	$(NOECHO)$(DTC_PREBUILT) -O dtb -o $@ $(MODULE_DTC_FLAGS) --symbols $<
