+func filterArm64MuslProcMacroFeatures(ctx ModuleContext, crateName string, features []string) []string {
+	if arm64MuslProcMacroFallback(ctx) && arm64MuslProcMacroFeatureCrate(crateName) {
+		return android.RemoveListFromList(features, []string{"proc-macro"})
+	}
+	return features
+}
+
+func filterArm64MuslProcMacroCfgs(ctx ModuleContext, crateName string, cfgs []string) []string {
+	if arm64MuslProcMacroFallback(ctx) && crateName == "proc_macro2" {
+		return android.RemoveListFromList(cfgs, []string{
+			"proc_macro_span",
+			"proc_macro_span_file",
+			"proc_macro_span_location",
+			"wrap_proc_macro",
+		})
+	}
+	return cfgs
+}
+
+func arm64MuslProcMacroFallback(ctx ModuleContext) bool {
+	return ctx.Target().Os == android.LinuxMusl && ctx.Target().Arch.ArchType == android.Arm64
+}
+
+func arm64MuslProcMacroFeatureCrate(crateName string) bool {
+	switch crateName {
+	case "proc_macro2", "quote", "syn", "synstructure":
+		return true
+	}
+	return false
+}
