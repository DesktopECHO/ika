+		entries, err := os.ReadDir(path)
+		if err != nil {
+			return nil, err
+		}
+		for _, entry := range entries {
+			mode := entry.Type()
+			if mode == 0 {
+				info, infoErr := entry.Info()
+				if infoErr != nil {
+					if os.IsNotExist(infoErr) {
+						continue
+					}
+					return contents, infoErr
+				}
+				mode = info.Mode() & (os.ModeType | os.ModeCharDevice)
+			}
+			contents = append(contents, &dirEntryInfo{
+				name:       entry.Name(),
+				mode:       mode,
+				modeExists: true,
+			})
+		}
+		return contents, nil
+	}
