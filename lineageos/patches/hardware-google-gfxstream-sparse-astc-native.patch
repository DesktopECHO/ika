+// Compressed-texture emulation expands one guest image into several host images. Sparse binds
+// describe only the guest-visible image, so sparse compressed images require the native path.
+static constexpr VkImageCreateFlags kSparseImageCreateFlags =
+    VK_IMAGE_CREATE_SPARSE_BINDING_BIT | VK_IMAGE_CREATE_SPARSE_RESIDENCY_BIT |
+    VK_IMAGE_CREATE_SPARSE_ALIASED_BIT;
