Patch summary:
Adapt the pinned Cuttlefish system_ext policy to this branch's platform sepolicy
API. This tree exposes date-based compat types such as platform_app_202504, not
platform_app_36, and does not define the newer platform_app_all aggregate. It
also only declares the older Trusty accessor service labels. Use the live
platform_app domain for the current platform app permissions, drop the
unsupported versioned fragment, keep the Trusty launcher registrations to
services this branch actually defines, and drop newer vendor policy fragments
unsupported by this branch's checkpolicy/sepolicy API.

diff --git a/shared/sepolicy/system_ext/private/platform_app_36.te b/shared/sepolicy/system_ext/private/platform_app_36.te
deleted file mode 100644
index b37b5232c..000000000
--- a/shared/sepolicy/system_ext/private/platform_app_36.te
+++ /dev/null
@@ -1,3 +0,0 @@
-# allow platform_app/systemui access to fingerprint
-hal_client_domain(platform_app_36, hal_fingerprint)
-hal_client_domain(platform_app_36, hal_face)
diff --git a/shared/sepolicy/system_ext/private/platform_app_all.te b/shared/sepolicy/system_ext/private/platform_app_all.te
index 5096dcbc8..7f6d3bcce 100644
--- a/shared/sepolicy/system_ext/private/platform_app_all.te
+++ b/shared/sepolicy/system_ext/private/platform_app_all.te
@@ -1,7 +1,7 @@
-get_prop(platform_app_all, vendor_aware_available_prop)
+get_prop(platform_app, vendor_aware_available_prop)
 
 # allow systemui to set boot animation colors
-set_prop(platform_app_all, bootanim_system_prop);
+set_prop(platform_app, bootanim_system_prop);
 
 # allow systemui access to bluetooth_lea_prop
-get_prop(platform_app_all, bluetooth_lea_prop)
+get_prop(platform_app, bluetooth_lea_prop)
