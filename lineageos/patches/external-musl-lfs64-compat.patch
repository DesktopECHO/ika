Patch summary:
Restore the musl host compatibility surface expected by Android's Rust host
toolchain on ARM64 build hosts. The patch makes musl header modules visible
outside `external/musl` and restores weak LFS64 alias symbols such as `open64`,
`stat64`, `mmap64`, and related entry points that musl 1.2.4 exposes only as
header macros. Android's prebuilt Rust musl stdlib still references the real
symbols through its host shim, so these aliases keep ARM64 host tools linkable
without changing x86 host behavior.

diff --git a/Android.bp b/Android.bp
index f8ed9cff..be83a8a7 100644
--- a/Android.bp
+++ b/Android.bp
@@ -19,6 +19,7 @@ license {
 
 cc_library_headers {
     name: "libc_musl_arch_headers",
+    visibility: ["//visibility:public"],
     host_supported: true,
     device_supported: false,
     system_shared_libs: [],
@@ -68,6 +69,7 @@ cc_library_headers {
 
 cc_library_headers {
     name: "libc_musl_public_headers",
+    visibility: ["//visibility:public"],
     host_supported: true,
     device_supported: false,
     system_shared_libs: [],
diff --git a/src/dirent/readdir.c b/src/dirent/readdir.c
index 5a03b363..9116ff22 100644
--- a/src/dirent/readdir.c
+++ b/src/dirent/readdir.c
@@ -25,3 +25,8 @@ struct dirent *readdir(DIR *dir)
 	dir->tell = de->d_off;
 	return de;
 }
+
+/* LineageOS: restore LFS64 alias symbol removed in musl 1.2.4 (GNU Rust std host shim).
+   musl exposes readdir64 only as a header macro; #undef it to define the real weak symbol. */
+#undef readdir64
+extern __typeof(readdir) readdir64 __attribute__((__weak__, __alias__("readdir")));
