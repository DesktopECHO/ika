Patch summary:
Let Trusty kernel host tooling run on ARM64 Linux hosts. DTB rules can use an
env-provided DTC instead of the legacy x86 prebuilt, and host tools/tests thread
optional Clang target and runtime flags so ARM64 musl host objects rebuild and
link against the checked-in runtimes. x86 hosts leave the variables empty and
preserve the existing defaults.

diff --git a/make/dtb.mk b/make/dtb.mk
index 78d3974..7b24198 100644
--- a/make/dtb.mk
+++ b/make/dtb.mk
@@ -39,7 +39,12 @@ MODULE_CPP_DTS := $(patsubst %.dts,$(BUILDDIR)/%.cpp.dts,$(MODULE_DTS))
 MODULE_DTB := $(patsubst %.cpp.dts,%.dtb,$(MODULE_CPP_DTS))
 MODULE_DTB_C := $(patsubst %.dtb,%.dtb.c,$(MODULE_DTB))
 
-DTC_PREBUILT := prebuilts/misc/linux-x86/dtc/dtc
+ifneq ($(strip $(DTC_PREBUILT)),)
+GLOBAL_DTC_PREBUILT := $(DTC_PREBUILT)
+endif
+ifeq ($(strip $(GLOBAL_DTC_PREBUILT)),)
+GLOBAL_DTC_PREBUILT := prebuilts/misc/linux-x86/dtc/dtc
+endif
 
 # Preprocess the .dts files
 $(MODULE_CPP_DTS): MODULE_DTS_INCLUDES := $(MODULE_DTS_INCLUDES)
@@ -50,7 +55,7 @@ $(MODULE_CPP_DTS): $(BUILDDIR)/%.cpp.dts: %.dts
 
 # Compile each .dts into a .dtb
 $(MODULE_DTB): MODULE_DTC_FLAGS := $(MODULE_DTC_FLAGS)
-$(MODULE_DTB): DTC_PREBUILT := $(DTC_PREBUILT)
+$(MODULE_DTB): DTC_PREBUILT := $(GLOBAL_DTC_PREBUILT)
 $(MODULE_DTB): %.dtb: %.cpp.dts
 	@$(MKDIR)
 	$(NOECHO)$(DTC_PREBUILT) -O dtb -o $@ $(MODULE_DTC_FLAGS) --symbols $<
diff --git a/make/generic_compile.mk b/make/generic_compile.mk
index bef406b..b136f32 100644
--- a/make/generic_compile.mk
+++ b/make/generic_compile.mk
@@ -43,7 +43,8 @@ ifeq ($(GENERIC_OBJ_DIR), )
 $(error GENERIC_OBJ_DIR must be specified)
 endif
 
-GENERIC_FLAGS += --sysroot $(CLANG_HOST_SYSROOT)
+GENERIC_FLAGS += $(CLANG_HOST_TARGET_FLAGS) --sysroot $(CLANG_HOST_SYSROOT)
+GENERIC_SRCDEPS += $(TOOLCHAIN_CONFIG)
 
 # Group the source files so we can differ the flags between C, C++, and assembly.
 GENERIC_C_SRCS := $(filter %.c,$(GENERIC_SRCS))
diff --git a/make/host_test.mk b/make/host_test.mk
index 9244786..432e3aa 100644
--- a/make/host_test.mk
+++ b/make/host_test.mk
@@ -49,7 +49,7 @@ HOST_TEST_BUILDDIR := $(TRUSTY_TOP_LEVEL_BUILDDIR)
 endif
 
 # We should use the prebuilt linker rather than the host linker
-HOST_LDFLAGS := -B$(CLANG_BINDIR) -B$(CLANG_HOST_SEARCHDIR) \
+HOST_LDFLAGS := $(CLANG_HOST_LINK_FLAGS) -B$(CLANG_BINDIR) -B$(CLANG_HOST_SEARCHDIR) \
 	$(foreach dir,$(CLANG_HOST_LDDIRS),-L$(dir)) --sysroot=$(CLANG_HOST_SYSROOT) -fuse-ld=lld
 
 HOST_CC := $(CLANG_BINDIR)/clang
diff --git a/make/host_tool.mk b/make/host_tool.mk
