+PRODUCT_COPY_FILES += \
+    frameworks/native/data/etc/aosp_excluded_hardware.xml:$(TARGET_COPY_OUT_VENDOR)/etc/permissions/aosp_excluded_hardware.xml
+
+PRODUCT_NAME := aosp_cf_arm64_desktop_pgagnostic
+PRODUCT_DEVICE := vsoc_arm64_pgagnostic
+PRODUCT_MANUFACTURER := DesktopECHO
+PRODUCT_MODEL := Cuttlefish arm64 desktop 64-bit only pgagnostic
+PRODUCT_MAX_PAGE_SIZE_SUPPORTED := 16384
+PRODUCT_NO_BIONIC_PAGE_SIZE_MACRO := true
+
+PRODUCT_VENDOR_PROPERTIES += \
+    ro.soc.manufacturer=$(PRODUCT_MANUFACTURER) \
+    ro.soc.model=$(PRODUCT_DEVICE)
+
+PRODUCT_16K_DEVELOPER_OPTION := true
+
+TARGET_BOOTS_16K := true
+
+# Ignore all Android.mk files
+PRODUCT_IGNORE_ALL_ANDROIDMK := true
