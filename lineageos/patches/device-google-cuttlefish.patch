+# limitations under the License.
+#
+
+#
+# Ika x86_64 target for Cuttlefish
+#
+
+TARGET_BOARD_PLATFORM := vsoc_x86_64
+TARGET_ARCH := x86_64
+TARGET_ARCH_VARIANT := sandybridge
+TARGET_CPU_ABI := x86_64
+TARGET_USERDATAIMAGE_FILE_SYSTEM_TYPE := ext4
+
+TARGET_NATIVE_BRIDGE_ARCH := arm64
+TARGET_NATIVE_BRIDGE_ARCH_VARIANT := armv8-a
+TARGET_NATIVE_BRIDGE_CPU_VARIANT := generic
+TARGET_NATIVE_BRIDGE_ABI := arm64-v8a
+
+# Native bridge uses Google's ndk_translation ELF prebuilts.
+ifeq ($(USE_NDK_TRANSLATION_BINARY),true)
+BUILD_BROKEN_ELF_PREBUILT_PRODUCT_COPY_FILES := true
+endif
+
+-include device/google/cuttlefish/shared/BoardConfig.mk
+-include device/google/cuttlefish/shared/bluetooth/BoardConfig.mk
+-include device/google/cuttlefish/shared/camera/BoardConfig.mk
+-include device/google/cuttlefish/shared/gnss/BoardConfig.mk
+-include device/google/cuttlefish/shared/graphics/BoardConfig.mk
+-include device/google/cuttlefish/shared/identity/BoardConfig.mk
+-include device/google/cuttlefish/shared/reboot_escrow/BoardConfig.mk
+-include device/google/cuttlefish/shared/sensors/BoardConfig.mk
+-include device/google/cuttlefish/shared/swiftshader/BoardConfig.mk
+-include device/google/cuttlefish/shared/telephony/BoardConfig.mk
+-include device/google/cuttlefish/shared/vibrator/BoardConfig.mk
+
+ifneq ($(BOARD_IS_AUTOMOTIVE), true)
+-include device/google/cuttlefish/shared/virgl/BoardConfig.mk
+endif
+
+# Keep snd-aloop out of the boot ramdisks so the loopback cannot claim ALSA
+# card 0 ahead of virtio-snd and swallow guest audio (see ika_arm64/BoardConfig.mk).
+BOARD_VENDOR_RAMDISK_KERNEL_MODULES := $(filter-out %/snd-aloop.ko,$(BOARD_VENDOR_RAMDISK_KERNEL_MODULES))
+BOARD_KERNEL_MODULES_16K := $(filter-out %/snd-aloop.ko,$(BOARD_KERNEL_MODULES_16K))
diff --git a/ika_x86_64/desktop/aosp_cf.mk b/ika_x86_64/desktop/aosp_cf.mk
new file mode 100644
index 000000000..41e06bf4c
--- /dev/null
+++ b/ika_x86_64/desktop/aosp_cf.mk
@@ -0,0 +1,86 @@
+#
+# Copyright (C) 2026 The Android Open Source Project
+#
+# Licensed under the Apache License, Version 2.0 (the "License");
+# you may not use this file except in compliance with the License.
+# You may obtain a copy of the License at
+#
+#      http://www.apache.org/licenses/LICENSE-2.0
+#
+# Unless required by applicable law or agreed to in writing, software
+# distributed under the License is distributed on an "AS IS" BASIS,
+# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+# See the License for the specific language governing permissions and
+# limitations under the License.
+#
+
+#
+# Ika x86_64 desktop target for Cuttlefish
+#
+
+#
+# All components inherited here go to system image (same as GSI system)
+#
+$(call inherit-product, $(SRC_TARGET_DIR)/product/core_64_bit_only.mk)
+$(call inherit-product, $(SRC_TARGET_DIR)/product/generic_system.mk)
+
+PRODUCT_ENFORCE_ARTIFACT_PATH_REQUIREMENTS := relaxed
+
+#
+# All components inherited here go to system_ext image (same as GSI system_ext)
+#
+$(call inherit-product, $(SRC_TARGET_DIR)/product/handheld_system_ext.mk)
+
+#
+# All components inherited here go to product image (same as GSI product)
+# Keep the non-telephony product surface while avoiding phone-only packages.
+#
+$(call inherit-product, $(SRC_TARGET_DIR)/product/handheld_product.mk)
+
+# Default AOSP sounds
+ifeq ($(LINEAGE_BUILD),)
+$(call inherit-product-if-exists, frameworks/base/data/sounds/AllAudio.mk)
+endif
+
+PRODUCT_PRODUCT_PROPERTIES += \
+    ro.config.ringtone?=Ring_Synth_04.ogg \
+    ro.config.notification_sound?=pixiedust.ogg \
+    ro.com.android.dataroaming?=true
+
+PRODUCT_PACKAGES += \
+    initial-package-stopped-states-aosp.xml \
+    PhotoTable \
+    preinstalled-packages-platform-aosp-product.xml \
+    ThemePicker
+
+# Keep Vulkan conformance tests opt-in; release images omit them by default.
+ifeq ($(LINEAGE_DESKTOP_BUILD_VULKAN_TESTS),true)
+PRODUCT_PACKAGES += deqp-binary
+endif
+
+#
+# All components inherited here go to vendor image
+#
+LOCAL_BT_LPP_SERVICE_INSTANCE_ENABLED := false
+LOCAL_NPU_HAL_PRODUCT_PACKAGE :=
+LOCAL_ENABLE_LIGHT := false
+$(call inherit-product, device/google/cuttlefish/shared/desktop/device_vendor.mk)
+
+#
+# Special settings for the target
+#
+$(call inherit-product, device/google/cuttlefish/vsoc_x86_64/bootloader.mk)
+
+# Exclude features that are not available on AOSP devices.
+PRODUCT_COPY_FILES += \
+    frameworks/native/data/etc/aosp_excluded_hardware.xml:$(TARGET_COPY_OUT_VENDOR)/etc/permissions/aosp_excluded_hardware.xml
+
+PRODUCT_NAME := aosp_cf_ika_x86_64
+PRODUCT_DEVICE := ika_x86_64
+PRODUCT_MANUFACTURER := DesktopECHO
+PRODUCT_MODEL := Ika x86_64 desktop
+
+PRODUCT_VENDOR_PROPERTIES += \
+    ro.surface_flinger.force_present_timestamp=true \
+    ro.soc.manufacturer=$(PRODUCT_MANUFACTURER) \
+    ro.soc.model=$(PRODUCT_DEVICE)
