diff --git a/shared/set_adb/set_adb.sh b/shared/set_adb/set_adb.sh
index 67aece73f..931e14695 100644
--- a/shared/set_adb/set_adb.sh
+++ b/shared/set_adb/set_adb.sh
@@ -1,2 +1,64 @@
 #!/system/bin/sh
-settings put global adb_enabled 1
+
+put_global() {
+    settings put global "$1" "$2" >/dev/null 2>&1
+}
+
+put_secure() {
+    settings put secure "$1" "$2" >/dev/null 2>&1
+}
+
+put_system() {
+    settings put system "$1" "$2" >/dev/null 2>&1
+}
+
+put_global adb_enabled 1
+setprop log.tag.GLF S
+setprop log.tag.libEGL S
+
+# Desktop-mode contract. These are intentionally re-applied each boot because this product is
+# desktop-only; drifting back into handheld windowing behavior makes Launcher and WM unstable.
+# hidden_api_policy=0 disables non-SDK API enforcement so apps like Firefox (Gecko calls
+# MessageQueue.next() via JNI from a non-platform domain) and Termux can run. With policy=1
+# Gecko's main-loop hook is blocked, the renderer aborts inside google-breakpad, and Firefox
+# enters a restart loop. Standard LineageOS uses 0 for app-compatibility reasons.
+put_global hidden_api_policy 0
+put_global enable_freeform_support 1
+put_global force_resizable_activities 1
+put_global enable_non_resizable_multi_window 1
+put_global override_desktop_mode_features 1
+put_global override_desktop_experience_features 1
+put_global force_desktop_mode_on_external_displays 1
+put_global stay_on_while_plugged_in 3
+put_secure user_setup_complete 1
+put_secure long_press_timeout 350
+put_system accelerometer_rotation 0
+put_system show_ime_with_hard_keyboard 0
+
+# microG GmsCore overlay appop. SYSTEM_ALERT_WINDOW is auto-granted to preinstalled apps but the
+# matching appop defaults to MODE_DEFAULT, which Settings.canDrawOverlays() treats as denied. That
+# makes microG's self-check report overlay permission as unchecked and can suppress pop-ups, push
+# notifications, and background sync. Re-assert MODE_ALLOWED each boot; the command is a no-op when
+# com.google.android.gms may be absent when no provider is selected.
+cmd appops set com.google.android.gms SYSTEM_ALERT_WINDOW allow >/dev/null 2>&1
+
+# Keep crash evidence in logcat/dropbox but avoid modal crash-report loops on the desktop.
+put_global send_action_app_error 0
+put_global show_first_crash_dialog 0
+put_global show_restart_in_crash_dialog 0
+put_global show_mute_in_crash_dialog 1
+put_secure anr_show_background 0
+put_secure show_first_crash_dialog_dev_option 0
+
+# First-boot provisioning. Use a desktop-specific sentinel because SettingsProvider overlays may
+# seed device_provisioned=1 before this service runs.
+if [ "$(settings get global lineage_desktop_provisioned)" != "1" ]; then
+    put_global device_provisioned 1
+    put_global auto_time_zone 0
+    locksettings set-disabled true
+    # User-mutable preferences are seeded once and then left alone, so a subsequent change in
+    # Settings is not clobbered on the next reboot. (R15)
+    put_system pointer_speed -7
+    put_system screen_off_timeout 2147483647
+    put_global lineage_desktop_provisioned 1
+fi
