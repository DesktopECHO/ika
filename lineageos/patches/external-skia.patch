Patch summary:
Expose the Skia color-management helper library to vendor modules that need it
for the desktop graphics/camera stack. This is a Soong visibility/availability
adjustment, not a behavioral change to Skia itself.

diff --git a/Android.bp b/Android.bp
index 2eed822b2b..2bdb1f309e 100644
--- a/Android.bp
+++ b/Android.bp
@@ -1136,6 +1136,7 @@ gensrcs {
 cc_library_static {
     name: "libskia_skcms",
     host_supported: true,
+    vendor_available: true,
     sdk_version: "current",
     srcs: [
         "modules/skcms/skcms.cc",
