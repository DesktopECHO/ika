+    private static boolean isTranslatedAbi(@Nullable String abi) {
+        if (TextUtils.isEmpty(abi)) {
+            return false;
+        }
+
+        final String isa = VMRuntime.getInstructionSet(abi);
+        return !TextUtils.isEmpty(SystemProperties.get("ro.dalvik.vm.isa." + isa));
+    }
+
+    private static int maybeCopyTranslatedNativeBinaries(
+            NativeLibraryHelper.Handle handle, File nativeLibraryRoot, String[] supportedAbis,
+            boolean useIsaSpecificSubdirs, boolean onIncremental, int abi) throws IOException {
+        if (abi < 0 || !isTranslatedAbi(supportedAbis[abi])) {
+            return abi;
+        }
+
+        // Native bridge app libraries must be real files; APK zip paths are unsafe for translated
+        // guest linkers.
+        Trace.traceBegin(TRACE_TAG_PACKAGE_MANAGER, "copyTranslatedNativeBinaries");
+        try {
+            final int copyRet = NativeLibraryHelper.copyNativeBinariesForSupportedAbi(
+                    handle, nativeLibraryRoot, new String[]{supportedAbis[abi]},
+                    useIsaSpecificSubdirs, onIncremental, true /* forceExtractNativeLibs */);
+            return copyRet >= 0 ? abi : copyRet;
+        } finally {
+            Trace.traceEnd(TRACE_TAG_PACKAGE_MANAGER);
+        }
+    }
+
+    private static int copyNativeBinariesForSupportedAbi(
+            NativeLibraryHelper.Handle handle, File nativeLibraryRoot, String[] supportedAbis,
+            boolean useIsaSpecificSubdirs, boolean onIncremental) throws IOException {
+        Trace.traceBegin(TRACE_TAG_PACKAGE_MANAGER, "copyNativeBinaries");
+        try {
+            return NativeLibraryHelper.copyNativeBinariesForSupportedAbi(handle,
+                    nativeLibraryRoot, supportedAbis, useIsaSpecificSubdirs, onIncremental);
+        } finally {
+            Trace.traceEnd(TRACE_TAG_PACKAGE_MANAGER);
+        }
+    }
+
+    private static int findSupportedAbi(
+            NativeLibraryHelper.Handle handle, String[] supportedAbis) {
+        Trace.traceBegin(TRACE_TAG_PACKAGE_MANAGER, "findSupportedAbi");
+        try {
+            return NativeLibraryHelper.findSupportedAbi(handle, supportedAbis);
+        } finally {
+            Trace.traceEnd(TRACE_TAG_PACKAGE_MANAGER);
+        }
+    }
