+                (tracking, value, stopTracking) -> {
+                    if (mUpdatingSlider) {
+                        return;
+                    }
+                    final int target = clamp(value + mMinVolume, mMinVolume, mMaxVolume);
+                    if (target != mAudioManager.getStreamVolume(AudioManager.STREAM_MUSIC)) {
+                        mAudioManager.setStreamVolume(
+                                AudioManager.STREAM_MUSIC,
+                                target,
+                                /* flags= */ 0);
+                    }
+                    if (stopTracking) {
+                        syncSliderWithCurrentVolume();
+                    }
+                };
+        mVolumeObserver =
+                new ContentObserver(new Handler(Looper.getMainLooper())) {
+                    @Override
+                    public void onChange(boolean selfChange) {
+                        syncSliderWithCurrentVolume();
+                    }
+                };
+        syncSliderWithCurrentVolume();
+    }
+
+    void registerCallbacks() {
+        if (mListening) {
+            return;
+        }
+        mListening = true;
+        mSlider.setOnChangedListener(mSliderListener);
+        mContext.getContentResolver()
+                .registerContentObserver(
+                        Settings.System.getUriFor(Settings.System.VOLUME_MUSIC),
+                        false,
+                        mVolumeObserver,
+                        UserHandle.USER_ALL);
+        syncSliderWithCurrentVolume();
+    }
+
+    void unregisterCallbacks() {
+        if (!mListening) {
+            return;
+        }
+        mListening = false;
+        mSlider.setOnChangedListener(null);
+        mContext.getContentResolver().unregisterContentObserver(mVolumeObserver);
+    }
+
+    void checkRestrictionAndSetEnabled() {
+        mSlider.showView();
+    }
+
+    private void syncSliderWithCurrentVolume() {
+        updateBounds();
+        final int currentVolume = mAudioManager.getStreamVolume(AudioManager.STREAM_MUSIC);
+        mUpdatingSlider = true;
+        mSlider.setValue(clamp(currentVolume - mMinVolume, 0, mSlider.getMax()));
+        mUpdatingSlider = false;
+    }
+
+    private void updateBounds() {
+        mMinVolume = mAudioManager.getStreamMinVolume(AudioManager.STREAM_MUSIC);
+        mMaxVolume = mAudioManager.getStreamMaxVolume(AudioManager.STREAM_MUSIC);
+        mSlider.setMax(Math.max(0, mMaxVolume - mMinVolume));
+    }
+
+    private static int clamp(int value, int min, int max) {
+        return Math.max(min, Math.min(max, value));
+    }
+}
