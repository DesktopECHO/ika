+ * limitations under the License.
+ */
+
+package com.android.systemui.qs;
+
+import android.content.BroadcastReceiver;
+import android.content.Context;
+import android.content.Intent;
+import android.content.IntentFilter;
+import android.media.AudioManager;
+
+import com.android.systemui.settings.brightness.ToggleSlider;
+
+/**
+ * Binds the QS slider view to media volume instead of display brightness.
+ */
+class QSMediaVolumeController implements ToggleSlider.Listener {
+    private static final int STREAM = AudioManager.STREAM_MUSIC;
+    private static final int STREAM_UNKNOWN = -1;
+
+    private final Context mContext;
+    private final ToggleSlider mControl;
+    private final AudioManager mAudioManager;
+
+    private boolean mExternalChange;
+    private boolean mListening;
+    private boolean mTrackingTouch;
+
+    private final BroadcastReceiver mVolumeReceiver = new BroadcastReceiver() {
+        @Override
+        public void onReceive(Context context, Intent intent) {
+            String action = intent.getAction();
+            if (!AudioManager.VOLUME_CHANGED_ACTION.equals(action)
+                    && !AudioManager.STREAM_DEVICES_CHANGED_ACTION.equals(action)
+                    && !AudioManager.STREAM_MUTE_CHANGED_ACTION.equals(action)) {
+                return;
+            }
+
+            int stream = intent.getIntExtra(AudioManager.EXTRA_VOLUME_STREAM_TYPE, STREAM_UNKNOWN);
+            if (stream == STREAM && !mTrackingTouch) {
+                updateSlider();
+            }
+        }
+    };
+
+    QSMediaVolumeController(Context context, ToggleSlider control) {
+        mContext = context;
+        mControl = control;
+        mAudioManager = context.getSystemService(AudioManager.class);
+        updateSlider();
+    }
+
+    public void registerCallbacks() {
+        if (mListening) {
+            updateSlider();
+            return;
+        }
+
+        mListening = true;
+        mControl.setOnChangedListener(this);
+        IntentFilter filter = new IntentFilter();
+        filter.addAction(AudioManager.VOLUME_CHANGED_ACTION);
+        filter.addAction(AudioManager.STREAM_DEVICES_CHANGED_ACTION);
+        filter.addAction(AudioManager.STREAM_MUTE_CHANGED_ACTION);
+        mContext.registerReceiver(mVolumeReceiver, filter, Context.RECEIVER_NOT_EXPORTED);
+        updateSlider();
+    }
+
+    public void unregisterCallbacks() {
+        if (!mListening) {
+            return;
+        }
+
+        mListening = false;
+        mControl.setOnChangedListener(null);
+        mContext.unregisterReceiver(mVolumeReceiver);
+    }
+
+    @Override
+    public void onChanged(boolean tracking, int value, boolean stopTracking) {
+        mTrackingTouch = tracking;
+        if (mExternalChange) {
+            return;
+        }
+
+        mAudioManager.setStreamVolume(STREAM, sliderValueToVolume(value), 0);
+        if (!tracking || stopTracking) {
+            updateSlider();
+        }
+    }
+
+    public void checkRestrictionAndSetEnabled() {
+        mControl.setEnforcedAdmin(null);
+        updateSlider();
+    }
+
+    private void updateSlider() {
+        int min = mAudioManager.getStreamMinVolume(STREAM);
+        int max = mAudioManager.getStreamMaxVolume(STREAM);
+        int volume = mAudioManager.getStreamVolume(STREAM);
+
+        mExternalChange = true;
+        try {
+            mControl.setMax(Math.max(0, max - min));
+            mControl.setValue(Math.max(0, Math.min(volume, max) - min));
+        } finally {
+            mExternalChange = false;
+        }
+    }
+
+    private int sliderValueToVolume(int value) {
+        int min = mAudioManager.getStreamMinVolume(STREAM);
+        int max = mAudioManager.getStreamMaxVolume(STREAM);
+        return Math.max(min, Math.min(max, min + value));
+    }
+}
