+        val repository = userRepositories.getProfile(userId)
+        val visibleTaskIds = repository.getExpandedTasksOrdered(displayId)
+        if (visibleTaskIds.isEmpty()) {
+            restoreMinimizedDesktopTasks(displayId, userId)
+            return
+        }
+
+        showDesktop(displayId, visibleTaskIds)
+    }
