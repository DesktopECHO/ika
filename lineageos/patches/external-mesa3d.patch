+    /*
+     * Gfxstream's generated wire protocol sends VkBindMemoryStatus::pResult to the host but does
+     * not return the host-written values to the guest.  Preserve maintenance6 semantics without
+     * requiring a lockstep host protocol change: submit every binding individually, record the
+     * corresponding command result in its status structure, and still attempt the remaining
+     * bindings after a failure.  A one-element bind has exactly the per-operation result required
+     * by VkBindMemoryStatus, while the first failure is a valid aggregate return value.
+     */
+    VkResult aggregateResult = VK_SUCCESS;
+    for (uint32_t i = 0; i < bindInfoCount; ++i) {
+        const VkResult bindResult = bindOne(1, &pBindInfos[i]);
+        const VkBindMemoryStatus* status =
+            vk_find_struct_const(pBindInfos[i].pNext, BIND_MEMORY_STATUS);
+        if (status && status->pResult) *status->pResult = bindResult;
+        if (aggregateResult == VK_SUCCESS && bindResult != VK_SUCCESS) {
+            aggregateResult = bindResult;
+        }
+    }
+    return aggregateResult;
