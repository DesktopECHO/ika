+void ResourceTracker::on_vkCmdPipelineBarrier2(void* context, VkCommandBuffer commandBuffer,
+                                               const VkDependencyInfo* pDependencyInfo) {
+    VkEncoder* enc = (VkEncoder*)context;
+    VkDependencyInfo updatedDependencyInfo = *pDependencyInfo;
+    std::vector<VkImageMemoryBarrier2> updatedImageMemoryBarriers;
+
+    if (pDependencyInfo->imageMemoryBarrierCount) {
+        updatedImageMemoryBarriers.assign(
+            pDependencyInfo->pImageMemoryBarriers,
+            pDependencyInfo->pImageMemoryBarriers + pDependencyInfo->imageMemoryBarrierCount);
+        for (auto& barrier : updatedImageMemoryBarriers) {
+            fixAndroidAhbImageBarrier2Layout(&barrier);
+        }
+        updatedDependencyInfo.pImageMemoryBarriers = updatedImageMemoryBarriers.data();
+    }
+
+    enc->vkCmdPipelineBarrier2(commandBuffer, &updatedDependencyInfo, true /* do lock */);
+}
