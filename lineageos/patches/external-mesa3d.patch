+name: "mesa3d"
+description:
+    "Mesa (or Mesa 3D) is a library which provides the OpenGL, OpenGL ES, EGL, "
+    "Vulkan and other standard graphics APIs, and the userspace part of the "
+    "graphics hardware drivers required to accelerate these APIs."
+
+third_party {
+  url {
