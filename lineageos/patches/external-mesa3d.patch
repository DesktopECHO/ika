+template <typename BindInfo, typename BindOne>
+static VkResult gfxstream_vk_bind_memory_with_individual_status(uint32_t bindInfoCount,
+                                                                const BindInfo* pBindInfos,
+                                                                BindOne bindOne) {
+    bool hasIndividualStatus = false;
+    for (uint32_t i = 0; i < bindInfoCount; ++i) {
+        if (vk_find_struct_const(pBindInfos[i].pNext, BIND_MEMORY_STATUS)) {
+            hasIndividualStatus = true;
+            break;
+        }
