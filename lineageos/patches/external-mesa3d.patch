+        [&](uint32_t count, const VkBindBufferMemoryInfo* infos) {
+            std::vector<VkBindBufferMemoryInfo> internalInfos(infos, infos + count);
+            for (uint32_t i = 0; i < count; ++i) {
+                VK_FROM_HANDLE(gfxstream_vk_buffer, gfxstream_buffer, internalInfos[i].buffer);
