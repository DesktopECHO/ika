+static void fixAndroidAhbImageBarrier2Layout(VkImageMemoryBarrier2* barrier) {
+#ifdef VK_USE_PLATFORM_ANDROID_KHR
+    // Android does not carry the current layout with imported AHardwareBuffers.
+    // Preserve their contents for synchronization2 just as the legacy barrier
+    // path above does.
+    if (barrier->srcQueueFamilyIndex != barrier->dstQueueFamilyIndex &&
+        (barrier->srcQueueFamilyIndex == VK_QUEUE_FAMILY_EXTERNAL ||
+         barrier->srcQueueFamilyIndex == VK_QUEUE_FAMILY_FOREIGN_EXT) &&
+        barrier->oldLayout == VK_IMAGE_LAYOUT_UNDEFINED) {
+        barrier->oldLayout = barrier->newLayout;
+    }
+#else
+    (void)barrier;
+#endif
+}
