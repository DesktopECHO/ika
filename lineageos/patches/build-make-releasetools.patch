+  boot_16k_image = os.path.join(unzip_dir, "IMAGES", "boot_16k.img")
+  if os.path.exists(boot_16k_image):
+    signed_boot_16k_image = common.MakeTempFile()
+    shutil.copy(boot_16k_image, signed_boot_16k_image)
+    common._SignBootableImage(signed_boot_16k_image, "boot.img", "boot", misc_info)
+    common.ZipWrite(output_tf_zip, signed_boot_16k_image, "IMAGES/boot_16k.img",
+                    compress_type=zipfile.ZIP_STORED)
