Patch summary:
Fall back to native host mogrify when the checked-in prebuilt cannot run.

Lineage's bootanimation genrule uses the tools-lineage linux-x86 mogrify
prebuilt. That works on x86 hosts, but ARM64 Linux hosts fail with an exec
format error when the script runs the x86 ELF. Keep the existing prebuilt path
as the first choice, and only use the system ImageMagick mogrify when the
genrule-provided tool is not executable on the current host.

diff --git a/bootanimation/gen-bootanimation.sh b/bootanimation/gen-bootanimation.sh
index 8c2ba50e..645ec092 100755
--- a/bootanimation/gen-bootanimation.sh
+++ b/bootanimation/gen-bootanimation.sh
@@ -28,6 +28,25 @@ PARAM_TARGET_BOOTANIMATION_HALF_RES=$9
 
 INTERMEDIATES=$PARAM_GENDIR/intermediates
 
+resolve_mogrify() {
+    local candidate=$1
+
+    if "$candidate" -version >/dev/null 2>&1; then
+        printf '%s\n' "$candidate"
+        return 0
+    fi
+
+    for candidate in /usr/bin/mogrify /bin/mogrify; do
+        if [ -x "$candidate" ] && "$candidate" -version >/dev/null 2>&1; then
+            printf '%s\n' "$candidate"
+            return 0
+        fi
+    done
+
+    echo "error: mogrify prebuilt is not executable and no host mogrify was found" >&2
+    return 126
+}
+
 mkdir -p $INTERMEDIATES
 
 tar xfp $PARAM_BOOTANIMATION_TAR -C $INTERMEDIATES
@@ -48,7 +67,9 @@ fi
 IMAGEHEIGHT=$(expr $IMAGEWIDTH / 3);
 RESOLUTION="$IMAGEWIDTH"x"$IMAGEHEIGHT";
 
-$PARAM_MOGRIFY -resize $RESOLUTION -colors 256 $INTERMEDIATES/*/*.png;
+MOGRIFY=$(resolve_mogrify "$PARAM_MOGRIFY")
+
+$MOGRIFY -resize $RESOLUTION -colors 256 $INTERMEDIATES/*/*.png;
 
 echo "$IMAGESCALEWIDTH $IMAGESCALEHEIGHT 60" > $INTERMEDIATES/desc.txt;
 cat $PARAM_DESC_TXT >> $INTERMEDIATES/desc.txt
