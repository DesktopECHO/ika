Patch summary:
Point Bison genrules at the checked-in build-tools data directory. Several
external projects invoke the prebuilt Bison binary from Soong genrules, but the
binary does not reliably discover its package data when launched from the build
sandbox. Setting `BISON_PKGDATADIR` from the Bison tool location keeps parser
generation host-independent for libpcap, one-true-awk, iproute2, and Mesa.

diff --git a/external/libpcap/Android.bp b/external/libpcap/Android.bp
index bf511871..a3a07818 100644
--- a/external/libpcap/Android.bp
+++ b/external/libpcap/Android.bp
@@ -46,7 +46,7 @@ genrule {
 
 genrule {
     name: "grammar.c",
-    cmd: "M4=$(location m4) $(location bison) -p pcap_ --no-lines --output=$(genDir)/grammar.c $(in)",
+    cmd: "BISON_PKGDATADIR=$$(dirname $$(dirname $$(dirname $(location bison))))/common/bison M4=$(location m4) $(location bison) -p pcap_ --no-lines --output=$(genDir)/grammar.c $(in)",
     out: ["grammar.c"],
     srcs: [":grammar.y"],
     tools: [
@@ -59,7 +59,7 @@ genrule {
     name: "grammar.h",
     // bison --defines outputs an extra file in addition to outputting the parser,
     // so we still use --output to ensure the unused file is still in genDir.
-    cmd: "M4=$(location m4) $(location bison) -p pcap_ --no-lines --defines=$(genDir)/grammar.h --output=$(genDir)/unused $(in)",
+    cmd: "BISON_PKGDATADIR=$$(dirname $$(dirname $$(dirname $(location bison))))/common/bison M4=$(location m4) $(location bison) -p pcap_ --no-lines --defines=$(genDir)/grammar.h --output=$(genDir)/unused $(in)",
     out: ["grammar.h"],
     srcs: [":grammar.y"],
     tools: [
