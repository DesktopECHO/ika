@@ -305,6 +305,13 @@ cflag_allowlist = [
     "-fno-unwind-tables",
 ]
 
+host_x86_cflag_allowlist = {
+    "-mpclmul",
+    "-mssse3",
+    "-msse3",
+    "-msse4.2",
+}
+
 # Linker flags which are passed through to the blueprint.
 ldflag_allowlist = [
     # flags to reduce binary size
@@ -2645,6 +2652,20 @@ def configure_cc_module(module, cflags, defines, ldflags, libs):
       module.cppflags.add('-fexceptions')
 
 
+def move_host_x86_cflags(module):
+  # GN's "host" arch means the x86_64 build host in Chromium, but Android.bp
+  # also uses it for host-cross ARM64 variants. Keep x86 feature flags on x86
+  # Linux hosts only so linux_musl_arm64 can build the same modules.
+  x86_cflags = module.target['host'].cflags & host_x86_cflag_allowlist
+  if not x86_cflags:
+    return
+  module.target['host'].cflags -= x86_cflags
+  for arch_name in ('linux_x86', 'linux_x86_64'):
+    if arch_name not in module.target:
+      module.target[arch_name] = module.Target(arch_name)
+    module.target[arch_name].cflags.update(x86_cflags)
+
+
 def set_module_include_dirs(module, cflags, include_dirs):
   for flag in cflags:
     if '-isystem' in flag:
@@ -2849,6 +2870,7 @@ def create_modules_from_target(blueprint, gn, gn_target_name, parent_gn_type,
