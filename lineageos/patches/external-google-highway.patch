Patch summary:
Make Google Highway available to vendor-side modules that depend on its SIMD
helpers in the desktop vendor build. This keeps the vendor camera/graphics
dependency graph using the upstream library instead of carrying a duplicate
copy or local shim.

diff --git a/Android.bp b/Android.bp
index 56cc9bf5..421822cf 100644
--- a/Android.bp
+++ b/Android.bp
@@ -18,6 +18,7 @@ license {
 cc_library {
     name: "libhwy",
     host_supported: true,
+    vendor_available: true,
     sdk_version: "current",
     stl: "c++_shared",
     export_include_dirs: [
