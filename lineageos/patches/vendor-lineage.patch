Patch summary:
Add Lineage-side desktop product plumbing. This is where the desktop product
ties into Lineage build conventions: optional app exclusions, clean launcher
workspace overlays, repo manifest generation under a Python with ssl support,
and defaults that do not naturally belong in AOSP device or framework projects.

The patch keeps product policy close to the Lineage vendor layer, so the AOSP
framework/device patches can stay focused on behavior and hardware contracts.
It also makes it easier to adjust packaged apps and overlay defaults without
rebasing the core desktop shell changes. The manifest rules use /usr/bin/python3
because AOSP's hermetic py3-cmd can lack _ssl, which breaks repo's ssl import.

diff --git a/build/tasks/build-manifest_xml.mk b/build/tasks/build-manifest_xml.mk
index 54a6f1bb..5f53291a 100644
--- a/build/tasks/build-manifest_xml.mk
+++ b/build/tasks/build-manifest_xml.mk
@@ -18,7 +18,7 @@ endif
 
 $(INSTALLED_BUILD_MANIFEST_XML_TARGET):
 	mkdir -p $(dir $@)
-	python3 .repo/repo/repo manifest -o - -r | grep -Ev "proprietary_$(MANIFEST_EXCLUDES)" > $@
+	/usr/bin/python3 .repo/repo/repo manifest -o - -r | grep -Ev "proprietary_$(MANIFEST_EXCLUDES)" > $@
 
 .PHONY: build-manifest.xml
 build-manifest.xml: $(INSTALLED_BUILD_MANIFEST_XML_TARGET)
diff --git a/build/tasks/kernel.mk b/build/tasks/kernel.mk
index 2ebc8824..d94afae4 100644
--- a/build/tasks/kernel.mk
+++ b/build/tasks/kernel.mk
@@ -752,7 +752,7 @@ KERNEL_PATH := $(abspath $(BUILD_TOP)/kernel/platform/kernel-$(TARGET_KERNEL_VER
 $(TARGET_PREBUILT_INT_KERNEL): $(DEPMOD) $(KERNEL_MODULES_PARTITION_FILE_LIST) $(SYSTEM_KERNEL_MODULES_PARTITION_FILE_LIST)
 	@echo "Building $(BOARD_KERNEL_IMAGE_NAME)"
 	@mkdir -p $(KERNEL_OUT)
-	$(hide) cd $(KERNEL_PATH) && python3 $(BUILD_TOP)/.repo/repo/repo manifest -o - -r |sed '/^  <project.*\/>$$/{/kernel\/platform\/kernel-$(TARGET_KERNEL_VERSION)/!d;}' |sed '/^  <project/,/  <\/project>/{/kernel\/platform\/kernel-$(TARGET_KERNEL_VERSION)/!d;}' |sed 's|kernel/platform/kernel-$(TARGET_KERNEL_VERSION)/||' > $(abspath $(KERNEL_OUT))/manifest.xml
+	$(hide) cd $(KERNEL_PATH) && /usr/bin/python3 $(BUILD_TOP)/.repo/repo/repo manifest -o - -r |sed '/^  <project.*\/>$$/{/kernel\/platform\/kernel-$(TARGET_KERNEL_VERSION)/!d;}' |sed '/^  <project/,/  <\/project>/{/kernel\/platform\/kernel-$(TARGET_KERNEL_VERSION)/!d;}' |sed 's|kernel/platform/kernel-$(TARGET_KERNEL_VERSION)/||' > $(abspath $(KERNEL_OUT))/manifest.xml
 	$(hide) cd $(KERNEL_PATH) && ./tools/bazel --output_user_root=$(abspath $(KERNEL_OUT)/bazel-out) --output_root=$(abspath $(KERNEL_OUT)/bazel-out) run --experimental_convenience_symlinks=ignore --cpu=$(KERNEL_ARCH) --repo_manifest $(abspath $(KERNEL_PATH)):$(abspath $(KERNEL_OUT)/manifest.xml) --config=stamp //$(KERNEL_SRC):$(TARGET_KERNEL_PLATFORM_TARGET)_dist -- --destdir=$(abspath $(KERNEL_OUT))
 	$(if $(BOOT_KERNEL_MODULES),\
 		$(call build-image-kernel-modules-lineage,$(addprefix $(KERNEL_OUT)/,$(BOOT_KERNEL_MODULES)),$(KERNEL_VENDOR_RAMDISK_MODULES_OUT),,$(KERNEL_VENDOR_RAMDISK_DEPMOD_STAGING_DIR),$(KERNEL_VENDOR_RAMDISK_KERNEL_MODULES_LOAD),,,)\
diff --git a/config/common.mk b/config/common.mk
index b961788f..26d724b7 100644
--- a/config/common.mk
+++ b/config/common.mk
@@ -142,15 +142,23 @@ PRODUCT_PACKAGES += \
 # Lineage packages
 ifeq ($(PRODUCT_IS_ATV),)
 PRODUCT_PACKAGES += \
-    ExactCalculator \
-    Jelly
+    ExactCalculator
+
+ifneq ($(strip $(LINEAGE_SKIP_JELLY)),true)
+PRODUCT_PACKAGES += \
+    Jelly
+endif
 endif
 
 ifeq ($(PRODUCT_IS_AUTOMOTIVE),)
 PRODUCT_PACKAGES += \
-    LineageParts \
+    LineageParts
+
+ifneq ($(strip $(LINEAGE_SKIP_SETUPWIZARD)),true)
+PRODUCT_PACKAGES += \
     LineageSetupWizard
 endif
+endif
 
 PRODUCT_PACKAGES += \
     LineageSettingsProvider \
