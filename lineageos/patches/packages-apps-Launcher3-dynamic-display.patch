     private fun getCurrentDisplaySize(dragLayer: InsettableFrameLayout): Point {
+        val windowBounds =
+            context.getSystemService(WindowManager::class.java)?.currentWindowMetrics?.bounds
+        if (windowBounds != null && windowBounds.width() > 0 && windowBounds.height() > 0) {
+            return Point(windowBounds.width(), windowBounds.height())
+        }
+
         val deviceProperties = mActivityContext?.deviceProfile?.deviceProperties
         val displaySize =
             Point(
