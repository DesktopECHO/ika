     private fun getTaskbarTargetObjectLocation(outPos: Rect) {
-        val fullBounds = Rect()
-        popupContainer.getDescendantRectRelativeToSelf(originalView, fullBounds)
+        // Fix 2d: anchor the popup against the taskbar bar's top edge, not the
+        // icon's layout-rect top. The taskbar drag layer is laid out as
+        // wrap_content, so popupContainer.height is 0 during the popup's
+        // measure pass (before the dragLayer expands around the popup). The
+        // taskbar also parents its icons at the top of the drag layer and
+        // renders them at the bottom via a translation that
+        // getDescendantRectRelativeToSelf does not reflect either.
+        // Compose the rect from the icon's screen-relative horizontal position
+        // (for centering on the clicked icon), live window metrics, and the
+        // current taskbar profile height/margin. Keep the vertical coordinates
+        // in the drag layer's logical display coordinate space; the taskbar
+        // content may report a screen Y offset equal to the bar's top edge, and
+        // subtracting that offset collapses the target top back to 0. Result:
+        // popup hovers immediately above the bar with the existing
+        // TASKBAR_POPUP_EXTRA_VERTICAL_OFFSET_PX gap.
+        val iconScreenPos = IntArray(2)
+        originalView.getLocationOnScreen(iconScreenPos)
+        val containerScreenPos = IntArray(2)
+        popupContainer.getLocationOnScreen(containerScreenPos)
         val iconBounds = Rect()
         originalIcon.getIconBounds(iconBounds)
+        val dp = mActivityContext?.deviceProfile
+        val screenHeight = getCurrentDisplaySize(popupContainer).y
+        val taskbarHeight = dp?.taskbarProfile?.height ?: originalView.height
+        val taskbarBottomMargin = dp?.taskbarProfile?.bottomMargin ?: 0
+        val taskbarTopInContainer = screenHeight - taskbarHeight - taskbarBottomMargin
+        val bottomInContainer = screenHeight - taskbarBottomMargin
+        val leftInContainer = iconScreenPos[0] - containerScreenPos[0]

         outPos.set(
-            fullBounds.left + iconBounds.left,
-            fullBounds.top + iconBounds.top,
-            fullBounds.left + iconBounds.right,
-            fullBounds.top + iconBounds.bottom,
+            leftInContainer + iconBounds.left,
+            taskbarTopInContainer,
+            leftInContainer + iconBounds.right,
+            bottomInContainer,
         )
-
-        val visibleBounds = Rect()
-        if (originalView.getLocalVisibleRect(visibleBounds)) {
-            val visibleRect =
-                Rect(
-                    fullBounds.left + visibleBounds.left,
-                    fullBounds.top + visibleBounds.top,
-                    fullBounds.left + visibleBounds.right,
-                    fullBounds.top + visibleBounds.bottom,
-                )
-            outPos.intersect(visibleRect)
-        }
     }

