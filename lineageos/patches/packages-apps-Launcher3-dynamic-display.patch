-            size = mDeviceProfile.getDeviceProperties().getHeightPx();
+            size = getCurrentFullscreenTaskbarWindowSize(landscapePhoneButtonNav);
         } else {
             mLastRequestedNonFullscreenSize = size;
             if (mIsFullscreen || mIsTaskbarSizeFrozenForAnimatingBubble) {
@@ -1475,6 +1475,17 @@
         notifyUpdateLayoutParams();
     }

+    private int getCurrentFullscreenTaskbarWindowSize(boolean landscapePhoneButtonNav) {
+        Rect currentBounds = mWindowManager.getCurrentWindowMetrics().getBounds();
+        int currentSize = landscapePhoneButtonNav ? currentBounds.width() : currentBounds.height();
+        if (currentSize > 0) {
+            return currentSize;
+        }
+        return landscapePhoneButtonNav
+                ? mDeviceProfile.getDeviceProperties().getWidthPx()
+                : mDeviceProfile.getDeviceProperties().getHeightPx();
+    }
+
     /**
      * Returns the default size (in most cases height, but in 3-button phone mode, width) of the
      * window, including the static corner radii above taskbar.
