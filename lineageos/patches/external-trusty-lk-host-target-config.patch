Patch summary:
Record Trusty's optional Clang host target/link flags in toolchain.config.
ARM64 host builds set CLANG_HOST_TARGET_FLAGS and CLANG_HOST_LINK_FLAGS so
Trusty host tools/tests compile and link against the musl target that matches
the checked-in ARM64 runtimes. Include those values in the toolchain config so
incremental builds notice target flag changes. The values are empty on x86
hosts, preserving the existing default behavior.

diff --git a/engine.mk b/engine.mk
index 95b9a269..578c9dd2 100644
--- a/engine.mk
+++ b/engine.mk
@@ -450,6 +450,8 @@ CLIPPY_DRIVER := $(RUST_BINDIR)/clippy-driver
 # needed to force a rebuild when changing compiler versions.
 TOOLCHAIN_DEFINES := CLANG_BINDIR=\"$(subst $(SPACE),_,$(CLANG_BINDIR))\"
 TOOLCHAIN_DEFINES += CLANG_TOOLS_BINDIR=\"$(subst $(SPACE),_,$(CLANG_TOOLS_BINDIR))\"
+TOOLCHAIN_DEFINES += CLANG_HOST_TARGET_FLAGS=\"$(subst $(SPACE),_,$(CLANG_HOST_TARGET_FLAGS))\"
+TOOLCHAIN_DEFINES += CLANG_HOST_LINK_FLAGS=\"$(subst $(SPACE),_,$(CLANG_HOST_LINK_FLAGS))\"
 TOOLCHAIN_DEFINES += RUST_BINDIR=\"$(subst $(SPACE),_,$(RUST_BINDIR))\"
 $(TOOLCHAIN_CONFIG): configheader
 	@$(call INFO_DONE,toolchain,generating config file,$@)
