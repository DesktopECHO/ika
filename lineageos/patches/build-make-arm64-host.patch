diff --git a/core/envsetup.mk b/core/envsetup.mk
index 7a264859dd..87526857d4 100644
--- a/core/envsetup.mk
+++ b/core/envsetup.mk
@@ -176,6 +176,10 @@ ifneq (,$(findstring x86_64,$(UNAME)))
   HOST_ARCH := x86_64
   HOST_2ND_ARCH := x86
   HOST_IS_64_BIT := true
+else ifneq (,$(findstring aarch64,$(UNAME))$(findstring arm64,$(UNAME)))
+  HOST_ARCH := arm64
+  HOST_2ND_ARCH :=
+  HOST_IS_64_BIT := true
 else
 ifneq (,$(findstring i686,$(UNAME))$(findstring x86,$(UNAME)))
 $(error Building on a 32-bit x86 host is not supported: $(UNAME)!)
@@ -244,8 +248,15 @@ $(error HOST_BUILD_TYPE must be either release or debug, not '$(HOST_BUILD_TYPE)
 endif
 endif
 
-# We don't want to move all the prebuilt host tools to a $(HOST_OS)-x86_64 dir.
-HOST_PREBUILT_ARCH := x86
+# We don't want to move all the x86 prebuilt host tools to a $(HOST_OS)-x86_64 dir.
+ifeq ($(HOST_ARCH),arm64)
+  HOST_PREBUILT_ARCH := arm64
+  # Soong builds ARM64 Linux host tools against musl; keep Make's host tool
+  # output paths and link rules in sync with that choice.
+  USE_HOST_MUSL := true
+else
+  HOST_PREBUILT_ARCH := x86
+endif
 # This is the standard way to name a directory containing prebuilt host
 # objects. E.g., prebuilt/$(HOST_PREBUILT_TAG)/cc
 # This must match the logic in get_host_prebuilt_prefix in envsetup.sh
