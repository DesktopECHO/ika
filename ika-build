#!/usr/bin/env bash
#
# ika-build — one-shot builder for the ika stack. Runs from a checkout of this
# repository and, in order:
#
#   1. creates/verifies ROM signing keys  (tools/buildutils/setup_keys.sh)
#   2. installs build dependencies        (tools/buildutils/lib/dependencies.sh)
#   3. builds the LineageOS Desktop ROM   (lineageos/scripts/build_lineageos_desktop.sh)
#   4. builds the host packages           (tools/buildutils/build_packages.sh)
#   5. prints instructions to install ika-base and ika-lineageos
#
# Build dependencies are installed before the long ROM build and wait for
# password input if needed. A reboot is required after installing; this script
# makes that explicit.

set -euo pipefail

repo_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "${repo_dir}"

# Reuse the canonical distro detection used by the build scripts, and the
# combined build-dependency installer.
source "${repo_dir}/tools/buildutils/lib/common.sh"
source "${repo_dir}/tools/buildutils/lib/dependencies.sh"
source "${repo_dir}/tools/buildutils/lib/package_versions.sh"
source "${repo_dir}/lineageos/scripts/signing_common.sh"
source "${repo_dir}/lineageos/scripts/lib/gms_provider.sh"

refuse_root_build

readonly ROM_BUILD="./lineageos/scripts/build_lineageos_desktop.sh"
readonly PKG_BUILD="./tools/buildutils/build_packages.sh"
readonly INSTALL_BAZEL="./tools/buildutils/installbazel.sh"
readonly PRIMARY_PACKAGES=(ika-base ika-lineageos)

declare -a rom_args=()
declare -a rom_provider_args=()
declare -a pkg_files=()
family=""
privileged_preflight_active=false

usage() {
  cat <<EOF
Usage: ./ika-build [options] [all|arm64|x86_64]...

Prepares LineageOS signing certificates, installs build dependencies, builds
the ROM and host packages, then prints the command needed to install
${PRIMARY_PACKAGES[*]}.

Options:
      --microg     Include microG in the ROM.
      --mtg        Include MindTheGapps in the ROM.
  -h, --help       Show this help and exit.

By default only the host's native ROM (arm64 or x86_64) is built. Pass optional
target arguments (all, arm64, and/or x86_64) to build a different or wider set.
When run without any arguments, ika-build asks which Google integration to use.
EOF
}

banner() {
  printf '\n==> %s\n' "$*"
}

print_lineageos_build_next_steps() {
  cat <<'EOF'

Next steps:
  ./lineageos/scripts/build_lineageos_desktop.sh           # starting now
  ./lineageos/scripts/rebuild_cf_desktop_arm64.sh          # fast rebuild after source edits
  ./lineageos/scripts/rebuild_cf_desktop_x86_64.sh

EOF
}

signing_keys_already_configured() {
  [[ -f "$ANDROID_CERTS_DIR/releasekey.pk8" ]] || return 1
  [[ -x "$GENERATE_KEYS_SCRIPT" ]] || return 1
  "$GENERATE_KEYS_SCRIPT" --check >/dev/null 2>&1
}

print_reboot_notice() {
  cat <<'EOF'

============================================================================
  REBOOT REQUIRED
============================================================================

  After package installation, you MUST reboot before Android can be started.

  Installing ika-base adds your user to the kvm, cvdnetwork, render, and
  video groups and installs udev rules, PAM resource limits, and the
  Cuttlefish host resources. Your current login session, its limits, and the
  live /dev/kvm permissions do NOT pick up this new state until you reboot.
  Logging out and back in is NOT enough.

      sudo reboot

  After rebooting, launch the device with:

      ika start

============================================================================
EOF
}

print_manual_install() {
  local cmd
  local -a installed_base=()
  local -a install_paths=()
  local install_command=""
  install_package_paths install_paths
  mapfile -t installed_base < <(installed_target_packages ika-base)

  build_manual_package_install_command "$family" install_command "${install_paths[@]}" || \
    return 1
  cmd="${install_command}"

  cat <<EOF

============================================================================
To install, run this from ${repo_dir}:
============================================================================

  ${cmd}

EOF

  # If ika-base is not currently installed, that manual command is a first-time
  # host install and a reboot is required afterward. Replacing an existing
  # ika-base package does not need one.
  if (( ${#installed_base[@]} == 0 )); then
    print_reboot_notice
  fi
}

newest_path() {
  local -a paths=("$@")
  local path

  (( ${#paths[@]} )) || return 1

  for path in "${paths[@]}"; do
    printf '%s\0' "${path}"
  done | sort -zV | tr '\0' '\n' | tail -n 1
}

host_rpm_arch() {
  if command -v rpm >/dev/null 2>&1; then
    rpm --eval '%{_arch}'
  else
    uname -m
  fi
}

install_package_paths() {
  local -n paths_ref="$1"
  local pkg_path

  paths_ref=()
  for pkg_path in "${pkg_files[@]}"; do
    case "${pkg_path}" in
      /*|./*|../*) paths_ref+=("${pkg_path}") ;;
      *)           paths_ref+=("./${pkg_path}") ;;
    esac
  done
}

# Populate pkg_files with the built primary packages for the detected distro.
collect_packages() {
  local pkg
  local -a found
  local selected
  local rpm_arch=""
  local -a missing=()

  pkg_files=()
  if [[ "${family}" == "rpm" ]]; then
    rpm_arch="$(host_rpm_arch)"
  fi

  shopt -s nullglob
  for pkg in "${PRIMARY_PACKAGES[@]}"; do
    case "${family}" in
      rpm)    found=( rpmbuild/RPMS/"${rpm_arch}"/"${pkg}"-[0-9]*.rpm ) ;;
      debian) found=( deb/"${pkg}"_*.deb ) ;;
      arch)   found=( archbuild/packages/"${pkg}"-[0-9]*.pkg.tar.* ) ;;
    esac
    if [[ "${family}" == "arch" && ${#found[@]} -gt 0 ]]; then
      local -a unsigned=()
      for selected in "${found[@]}"; do
        [[ "${selected}" == *.sig ]] || unsigned+=("${selected}")
      done
      found=("${unsigned[@]}")
    fi

    if (( ${#found[@]} )); then
      selected="$(newest_path "${found[@]}")"
      pkg_files+=("${selected}")
    else
      missing+=("${pkg}")
    fi
  done

  if (( ${#missing[@]} )); then
    banner "Warning: could not find built package(s): ${missing[*]}"
    echo "They may have been skipped during the build (for example ika-lineageos" >&2
    echo "when the lineageos-<arch> bundle is absent). Review the output above." >&2
  fi
}

# Print the subset of named packages that is currently installed.
installed_target_packages() {
  local -a packages=()
  local pkg

  if (( $# )); then
    packages=("$@")
  else
    packages=("${PRIMARY_PACKAGES[@]}")
  fi

  for pkg in "${packages[@]}"; do
    case "${family}" in
      rpm)
        if rpm -q --quiet "${pkg}"; then
          printf '%s\n' "${pkg}"
        fi
        ;;
      debian)
        if dpkg-query -W -f='${Status}\n' "${pkg}" 2>/dev/null \
             | grep -q 'install ok installed'; then
          printf '%s\n' "${pkg}"
        fi
        ;;
      arch)
        if pacman -Q "${pkg}" >/dev/null 2>&1; then
          printf '%s\n' "${pkg}"
        fi
        ;;
    esac
  done
}

cleanup_privileged_preflight_on_exit() {
  local status=$?
  stop_sudo_keepalive || true
  if [[ "${privileged_preflight_active}" == true ]]; then
    cleanup_lineageos_privileged_host || true
  fi
  exit "$status"
}

add_rom_arg() {
  case "$1" in
    all|arm64|x86_64)
      rom_args+=("$1")
      ;;
    -*)
      echo "Unrecognized option: $1" >&2
      echo "Run ./ika-build --help for usage." >&2
      exit 1
      ;;
    *)
      echo "Unrecognized argument: $1" >&2
      echo "Supported ROM targets are: all, arm64, x86_64." >&2
      exit 1
      ;;
  esac
}

add_rom_provider_arg() {
  local option="$1"
  local existing="${rom_provider_args[0]:-}"
  if [[ -n "$existing" && "$existing" != "$option" ]]; then
    echo "--microg and --mtg cannot be used together." >&2
    exit 1
  fi
  rom_provider_args=("$option")
}

if (( $# == 0 )); then
  if [[ ! -t 0 ]]; then
    echo "No arguments were provided and input is not interactive." >&2
    echo "Pass --microg, --mtg, or an explicit ROM target." >&2
    exit 1
  fi

  selected_provider=""
  if ! prompt_gms_provider selected_provider; then
    echo "Could not select Google integration: $GMS_PROVIDER_PARSE_ERROR" >&2
    exit 1
  fi
  case "$selected_provider" in
    microg) rom_provider_args=(--microg) ;;
    mtg) rom_provider_args=(--mtg) ;;
    none) ;;
  esac
  echo
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    --microg|--mtg) add_rom_provider_arg "$1"; shift ;;
    -h|--help)       usage; exit 0 ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        add_rom_arg "$1"
        shift
      done
      break
      ;;
    *)
      add_rom_arg "$1"
      shift
      ;;
  esac
done

family="$(detect_distro_family)"

needs_privileged_setup=false

if signing_keys_already_configured; then
  banner "LineageOS signing certificates already configured"
else
  banner "Preparing LineageOS signing certificates"
fi
echo
ensure_signing_keys

# Install dependencies and run privileged host preflight before the long ROM
# build starts, so it does not stop hours later on a sudo prompt.
if build_dependency_packages_need_install "${family}"; then
  needs_privileged_setup=true
  banner "Installing build dependencies (sudo)"
else
  banner "Build dependency packages already installed"
fi
echo

init_root_cmd
# Keep the sudo timestamp warm across the whole privileged setup phase so a
# single password entry covers dependency install and host preflight without
# a mid-phase re-prompt stalling an unattended build.
if [[ "${needs_privileged_setup}" == true ]]; then
  start_sudo_keepalive
fi
install_build_dependencies "${family}"
install_bazel_if_missing "${INSTALL_BAZEL}"
build_workspace="${WORKSPACE:-$repo_dir/lineageos/src}"
privileged_preflight_active=true
trap cleanup_privileged_preflight_on_exit EXIT
prepare_lineageos_privileged_host "$repo_dir" "$build_workspace"
# Privileged setup is done; let the timestamp lapse normally during the
# multi-hour, unprivileged ROM build.
stop_sudo_keepalive

# With no explicit target, build only the host-native ROM rather than every
# architecture. Explicit arguments (all/arm64/x86_64) still override this.
if (( ${#rom_args[@]} == 0 )); then
  rom_args=("$(ika_arch_for_host)")
fi

print_lineageos_build_next_steps
banner $'Building the LineageOS Desktop ROM\n    NOTE: First run will take a long time, 3 to 6+ hours.'
echo
sleep 2
if ! "${ROM_BUILD}" "${rom_provider_args[@]}" "${rom_args[@]}"; then
  echo "LineageOS Desktop ROM build failed; not building host packages." >&2
  exit 1
fi
cleanup_lineageos_privileged_host
privileged_preflight_active=false
trap - EXIT

banner "Building the host packages"
echo
"${PKG_BUILD}"

collect_packages

if (( ${#pkg_files[@]} == 0 )); then
  echo "No ika packages were found to install; nothing to do." >&2
  exit 1
fi

print_manual_install
