# Configuration for the cuttlefish-host-resources service.
#
# The ika workflow uses per-user cvdalloc networking, so this service performs
# only host setup -- it does not create bridges, NAT, or dnsmasq. The only
# tunables are the udmabuf caps it writes to /sys/module/udmabuf/parameters/ on
# each boot (raised above the kernel defaults for the gfxstream Vulkan
# host-visible path). Uncomment to override.

#udmabuf_list_limit=8192
#udmabuf_size_limit_mb=256
