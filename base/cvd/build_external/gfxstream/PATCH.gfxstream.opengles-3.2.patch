@@ -151,6 +151,11 @@ inline GlesVersion calcMaxESVersionFromCoreVersion(int coreMajor, int coreMinor)
             // 4.3 core has all the entry points we need, but we want 4.5 core for
             // ARB_ES31_compatibility to avoid shader translation (for now. TODO:
             // translate ESSL 310 to 4.3 shaders)
+            // OpenGL 4.6 provides the entry points required by the ES 3.2
+            // translator and supports GLSL 4.60 for translated ESSL 3.20.
+            if (coreMinor > 5) {
+                return EglOS::GlesVersion::ES32;
+            }
             return coreMinor > 4 ? EglOS::GlesVersion::ES31 : EglOS::GlesVersion::ES30;
         default:
             return EglOS::GlesVersion::ES2;
