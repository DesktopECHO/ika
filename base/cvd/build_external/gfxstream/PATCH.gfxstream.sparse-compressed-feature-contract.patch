+    // Sparse binding is a device-wide contract: once exposed, every otherwise-supported image
+    // format must accept VK_IMAGE_CREATE_SPARSE_BINDING_BIT. Compressed-texture emulation cannot
+    // satisfy that contract because its private decompression images are not guest sparse-bound.
+    // Keep native sparse support when the host natively exposes every advertised compressed set
+    // (for example Honeykrisp), but hide sparse support when an advertised set is emulated.
+    bool shouldDisableSparseBindingSupport(const VkPhysicalDeviceFeatures& hostFeatures) const {
+        return mDisableSparseBindingSupport ||
+               (enableEmulatedEtc2() && !hostFeatures.textureCompressionETC2) ||
+               (enableEmulatedAstc() && !hostFeatures.textureCompressionASTC_LDR);
+    }
+
+    bool shouldDisableSparseBindingSupport(VkPhysicalDevice physicalDevice,
+                                           VulkanDispatch* vk) const {
+        VkPhysicalDeviceFeatures hostFeatures{};
+        vk->vkGetPhysicalDeviceFeatures(physicalDevice, &hostFeatures);
+        return shouldDisableSparseBindingSupport(hostFeatures);
+    }
