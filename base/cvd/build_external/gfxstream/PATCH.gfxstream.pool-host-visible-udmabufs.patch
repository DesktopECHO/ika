+    // size matching also preserves Vulkan dma-buf import-size requirements.
+    const auto now = Clock::now();
+    for (auto& entry : pool->mEntries) {
+        if (entry->inUse || entry->size != memory.size() || entry->reusableAfter > now) {
+            continue;
+        }
