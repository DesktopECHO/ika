+    DescriptorType pooledMemory = fcntl(memory.getFd(), F_DUPFD_CLOEXEC, 0);
+    DescriptorType pooledUdmabuf = fcntl(udmabuf, F_DUPFD_CLOEXEC, 0);
+    if (pooledMemory < 0 || pooledUdmabuf < 0) {
+        if (pooledMemory >= 0) {
+            close(pooledMemory);
+        }
+        if (pooledUdmabuf >= 0) {
+            close(pooledUdmabuf);
+        }
+        close(udmabuf);
+        return std::nullopt;
+    }
+
+    const uint64_t id = pool->mNextId++;
+    pool->mEntries.emplace_back(std::make_unique<UdmabufPoolEntry>(
+        id, memory.size(), ManagedDescriptor(pooledMemory), ManagedDescriptor(pooledUdmabuf)));
+
+    return UdmabufAllocation{
+        .descriptor = udmabuf,
+        .lifetime = std::make_shared<UdmabufPoolLease>(pool, id),
+    };
 }
 
