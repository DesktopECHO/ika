 #include "gfxstream/memory/UdmabufCreator.h"
 
 namespace gfxstream {
 namespace base {
 
+namespace {
+
+using Clock = std::chrono::steady_clock;
+
+// Keep a short quarantine after both gfxstream owners release an allocation.
+// Resource unref and the VMM's final descriptor close happen synchronously in
+// practice, but the quarantine prevents an immediately following allocation
+// from racing that final close.
+constexpr auto kReuseQuarantine = std::chrono::milliseconds(250);
+
+struct UdmabufPoolEntry {
+    UdmabufPoolEntry(uint64_t idIn, size_t sizeIn, ManagedDescriptor memoryIn,
+                     ManagedDescriptor udmabufIn)
+        : id(idIn),
+          size(sizeIn),
+          memory(std::move(memoryIn)),
+          udmabuf(std::move(udmabufIn)) {}
+
+    uint64_t id;
+    size_t size;
+    ManagedDescriptor memory;
+    ManagedDescriptor udmabuf;
+    bool inUse = true;
+    Clock::time_point reusableAfter = Clock::time_point::max();
+};
+
+class UdmabufPoolState {
+   public:
+    void release(uint64_t id) {
+        std::lock_guard<std::mutex> lock(mMutex);
+        for (auto& entry : mEntries) {
+            if (entry->id != id) {
+                continue;
+            }
+            entry->inUse = false;
+            entry->reusableAfter = Clock::now() + kReuseQuarantine;
+            return;
+        }
+    }
+
+    std::mutex mMutex;
+    std::vector<std::unique_ptr<UdmabufPoolEntry>> mEntries;
+    uint64_t mNextId = 1;
+};
+
+class UdmabufPoolLease {
+   public:
+    UdmabufPoolLease(std::shared_ptr<UdmabufPoolState> state, uint64_t id)
+        : mState(std::move(state)), mId(id) {}
+
+    ~UdmabufPoolLease() {
+        if (mState) {
+            mState->release(mId);
+        }
+    }
+
+   private:
+    std::shared_ptr<UdmabufPoolState> mState;
+    uint64_t mId;
+};
+
+// A renderer can create multiple VkEmulation objects over its lifetime. Share
+// one pool across all of their UdmabufCreator instances; an instance-local
+// pool would recreate every dma-buf when a guest graphics process restarts.
+std::shared_ptr<UdmabufPoolState> GetProcessUdmabufPool() {
+    static const auto pool = std::make_shared<UdmabufPoolState>();
+    return pool;
+}
+
+}  // namespace
+
+class UdmabufCreator::Impl {
+   public:
+    std::shared_ptr<UdmabufPoolState> pool = GetProcessUdmabufPool();
+};
