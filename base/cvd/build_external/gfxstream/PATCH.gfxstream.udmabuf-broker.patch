+    std::optional<UdmabufBrokerAllocation> requestFromBroker(size_t size) {
+        auto socketFd = mBrokerSocket.get();
+        if (!socketFd) {
+            const char* path = std::getenv("GFXSTREAM_UDMABUF_BROKER");
+            if (!path || !path[0] || std::strlen(path) >= sizeof(sockaddr_un::sun_path)) {
+                return std::nullopt;
+            }
+
+            int fd = socket(AF_UNIX, SOCK_SEQPACKET | SOCK_CLOEXEC, 0);
+            if (fd < 0) {
+                return std::nullopt;
+            }
+
+            sockaddr_un address = {};
+            address.sun_family = AF_UNIX;
+            std::strncpy(address.sun_path, path, sizeof(address.sun_path) - 1);
+            if (connect(fd, reinterpret_cast<const sockaddr*>(&address), sizeof(address)) < 0) {
+                close(fd);
+                return std::nullopt;
+            }
+            mBrokerSocket = ManagedDescriptor(fd);
+            socketFd = mBrokerSocket.get();
+        }
+
+        UdmabufBrokerRequest request = {
+            .size = static_cast<uint64_t>(size),
+        };
+        if (send(*socketFd, &request, sizeof(request), MSG_NOSIGNAL) != sizeof(request)) {
+            mBrokerSocket = ManagedDescriptor();
+            return std::nullopt;
+        }
+
+        UdmabufBrokerResponse response;
+        iovec io = {
+            .iov_base = &response,
+            .iov_len = sizeof(response),
+        };
+        char control[CMSG_SPACE(sizeof(DescriptorType) * 2)] = {};
+        msghdr message = {
+            .msg_iov = &io,
+            .msg_iovlen = 1,
+            .msg_control = control,
+            .msg_controllen = sizeof(control),
+        };
+        const ssize_t received = recvmsg(*socketFd, &message, MSG_CMSG_CLOEXEC);
+        if (received != sizeof(response) || response.magic != kBrokerMagic ||
+            (message.msg_flags & (MSG_TRUNC | MSG_CTRUNC))) {
+            mBrokerSocket = ManagedDescriptor();
+            return std::nullopt;
+        }
+        if (response.status != 0) {
+            // A valid broker refusal (notably its residency cap) must fail the
+            // allocation instead of falling back to a fresh, non-reusable
+            // udmabuf that would bypass the host-safety limit.
+            return UdmabufBrokerAllocation{};
+        }
+
+        std::array<DescriptorType, 2> descriptors = {-1, -1};
+        bool foundDescriptors = false;
+        for (cmsghdr* header = CMSG_FIRSTHDR(&message); header;
+             header = CMSG_NXTHDR(&message, header)) {
+            if (header->cmsg_level != SOL_SOCKET || header->cmsg_type != SCM_RIGHTS ||
+                header->cmsg_len < CMSG_LEN(sizeof(descriptors))) {
+                continue;
+            }
+            std::memcpy(descriptors.data(), CMSG_DATA(header), sizeof(descriptors));
+            foundDescriptors = true;
+            break;
+        }
+        if (!foundDescriptors || descriptors[0] < 0 || descriptors[1] < 0) {
+            for (DescriptorType descriptor : descriptors) {
+                if (descriptor >= 0) {
+                    close(descriptor);
+                }
+            }
+            mBrokerSocket = ManagedDescriptor();
+            return std::nullopt;
+        }
+
+        return UdmabufBrokerAllocation{
+            .memory = ManagedDescriptor(descriptors[0]),
+            .udmabuf = ManagedDescriptor(descriptors[1]),
+        };
+    }
+
