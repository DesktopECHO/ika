+fn maybe_disable_gfxstream_vulkan_on_apple_16k(gpu_params: &mut GpuParameters) {
+    let gfxstream_vulkan_mask = 1u64 << RUTABAGA_CAPSET_GFXSTREAM_VULKAN;
+    let gfxstream_gles_mask = 1u64 << RUTABAGA_CAPSET_GFXSTREAM_GLES;
+
+    if gpu_params.capset_mask & gfxstream_vulkan_mask == 0
+        || gpu_params.capset_mask & gfxstream_gles_mask == 0
+        || !is_apple_silicon_16k_host()
+    {
+        return;
+    }
+
+    gpu_params.capset_mask &= !gfxstream_vulkan_mask;
+    gpu_params.use_vulkan = Some(false);
+    warn!(
+        "disabling gfxstream-vulkan on Apple Silicon 16K-page host; keeping gfxstream GLES"
+    );
+}
+
+fn is_apple_silicon_16k_host() -> bool {
+    #[cfg(all(target_os = "linux", target_arch = "aarch64"))]
+    {
+        if base::pagesize() <= 4096 {
+            return false;
+        }
+
+        std::fs::read("/proc/device-tree/compatible")
+            .map(|compatible| {
+                compatible
+                    .split(|byte| *byte == 0)
+                    .any(|entry| entry.starts_with(b"apple,"))
+            })
+            .unwrap_or(false)
+    }
+
+    #[cfg(not(all(target_os = "linux", target_arch = "aarch64")))]
+    {
+        false
+    }
+}
