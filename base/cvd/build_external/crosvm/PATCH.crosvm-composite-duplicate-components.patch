+    #[test]
+    fn from_file_allows_duplicate_locked_component_paths() {
+        let component = NamedTempFile::new().unwrap();
+        component.as_file().set_len(8192).unwrap();
+
+        let mut composite_proto = CompositeDisk::new();
+        composite_proto.version = COMPOSITE_DISK_VERSION;
+        composite_proto.component_disks.push(ComponentDisk {
+            file_path: component.path().to_str().unwrap().to_string(),
+            offset: 0,
+            read_write_capability: ReadWriteCapability::READ_WRITE.into(),
+            ..ComponentDisk::new()
+        });
+        composite_proto.component_disks.push(ComponentDisk {
+            file_path: component.path().to_str().unwrap().to_string(),
+            offset: 4096,
+            read_write_capability: ReadWriteCapability::READ_WRITE.into(),
+            ..ComponentDisk::new()
+        });
+        composite_proto.length = 8192;
+
+        let mut composite_image = tempfile().unwrap();
+        composite_image.write_all(CDISK_MAGIC.as_bytes()).unwrap();
+        composite_proto
+            .write_to_writer(&mut composite_image)
+            .unwrap();
+        composite_image.rewind().unwrap();
+
+        CompositeDiskFile::from_file(
