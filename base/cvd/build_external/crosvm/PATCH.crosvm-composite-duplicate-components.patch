+#[derive(Clone, Debug, Eq, Hash, PartialEq)]
+struct OpenComponentDiskKey {
+    path: PathBuf,
+    is_read_only: bool,
+    is_sparse_file: bool,
+    is_overlapped: bool,
+    is_direct: bool,
+    lock: bool,
+    depth: u32,
+}
+
+fn open_component_disk(
+    key: OpenComponentDiskKey,
+    cache: &mut HashMap<OpenComponentDiskKey, Box<dyn DiskFile>>,
+) -> Result<Box<dyn DiskFile>> {
+    match cache.entry(key.clone()) {
+        Entry::Occupied(entry) => match entry.get().try_clone() {
+            Ok(disk) => Ok(disk),
+            Err(_) => open_component_disk_uncached(key),
+        },
+        Entry::Vacant(entry) => {
+            let disk = open_component_disk_uncached(key)?;
+            if let Ok(cloned_disk) = disk.try_clone() {
+                entry.insert(cloned_disk);
+            }
+            Ok(disk)
+        }
+    }
+}
+
+fn open_component_disk_uncached(key: OpenComponentDiskKey) -> Result<Box<dyn DiskFile>> {
+    open_disk_file(DiskFileParams {
+        path: key.path,
+        is_read_only: key.is_read_only,
+        is_sparse_file: key.is_sparse_file,
+        is_overlapped: key.is_overlapped,
+        is_direct: key.is_direct,
+        lock: key.lock,
+        depth: key.depth,
+    })
+    .map_err(|e| Error::DiskError(Box::new(e)))
+}
