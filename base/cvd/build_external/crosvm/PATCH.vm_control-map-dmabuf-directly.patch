diff --git a/src/lib.rs b/src/lib.rs
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -88,6 +88,7 @@ use rutabaga_gfx::RutabagaGralloc;
 use rutabaga_gfx::RutabagaMappedRegion;
 use rutabaga_gfx::RutabagaMesaHandle;
 use rutabaga_gfx::VulkanInfo;
+use rutabaga_gfx::RUTABAGA_HANDLE_TYPE_MEM_DMABUF;
 use serde::de::Error;
 use serde::Deserialize;
 use serde::Serialize;
@@ -486,6 +487,27 @@ impl VmMemorySource {
                 driver_uuid,
                 size,
             } => {
+                // A dma-buf is already a file-backed, mmap-capable memory object. Mapping it
+                // directly avoids creating a second Vulkan device-memory import solely to
+                // obtain a CPU address. In addition to being cheaper, this gives the mapping a
+                // simple lifetime: UnregisterMemory drops the MemoryMapping and releases the
+                // dma-buf immediately.
+
+                // This is particularly important for gfxstream's host-visible Vulkan memory.
+                // gfxstream exports those allocations as udmabuf dma-bufs. Importing them into
+                // Vulkano transferred descriptor ownership through a second Vulkan allocation;
+                // after guest unmap, the Vulkan mapping disappeared but the imported dma-buf
+                // descriptors remained open in crosvm and pinned all backing pages. Opaque
+                // Vulkan handles still require the gralloc import path below.
+                if handle_type == RUTABAGA_HANDLE_TYPE_MEM_DMABUF {
+                    let mapped_region = map_descriptor(&descriptor, 0, size, prot)?;
+                    return Ok((
+                        mapped_region,
+                        size,
+                        Some(descriptor),
+                    ));
+                }
+
                 let device_id = rutabaga_gfx::DeviceId {
                     device_uuid,
                     driver_uuid,
                 };
