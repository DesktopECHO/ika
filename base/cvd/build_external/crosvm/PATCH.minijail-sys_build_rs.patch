+fn find_minijail_root() -> io::Result<PathBuf> {
+    // With build_script_rundir=".", cwd is the Bazel exec root.
+    // The minijail sources live under the crosvm repo checkout whose
+    // canonical name may vary between Bazel versions (e.g.
+    // +_repo_rules6+crosvm, +_repo_rules2+crosvm, etc.).
+    // Scan external/ to find it dynamically.
+    let cwd = env::current_dir()?;
+    let external = cwd.join("external");
+    if external.is_dir() {
+        for entry in std::fs::read_dir(&external)? {
+            let candidate = entry?.path().join("third_party/minijail");
+            if candidate.join("Makefile").exists()
+                && candidate.join("libminijail.h").exists()
+            {
+                return Ok(candidate);
+            }
+        }
+    }
+    Err(io::Error::new(io::ErrorKind::NotFound,
+        "could not locate minijail root under external/*/third_party/minijail"))
+}
