+    }
+
+    let arch = env::var("CARGO_CFG_TARGET_ARCH").unwrap();
+    let os = env::var("CARGO_CFG_TARGET_OS").unwrap();
+    let env_name = env::var("CARGO_CFG_TARGET_ENV").unwrap();
+    format!("{}-{}-{}-", arch, os, env_name)
