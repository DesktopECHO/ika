+
+fn find_minigbm_root() -> io::Result<PathBuf> {
+    // With build_script_rundir=".", cwd is the Bazel exec root. The minigbm
+    // repo is added as build_script_data under external/* with a canonical
+    // name that may vary across Bazel versions.
+    let cwd = env::current_dir()?;
+    let external = cwd.join("external");
+    if external.is_dir() {
+        for entry in fs::read_dir(&external)? {
+            let candidate = entry?.path();
+            if candidate.join("Makefile").exists() && candidate.join("gbm.h").exists() {
+                return Ok(candidate);
+            }
+        }
+    }
+    Err(io::Error::new(
+        io::ErrorKind::NotFound,
+        "could not locate minigbm root under external/*",
+    ))
+}
