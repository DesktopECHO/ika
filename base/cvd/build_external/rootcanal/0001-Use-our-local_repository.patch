From 8ac992a7ccfc7c9d7b34ea16b2d4d3659a6cab12 Mon Sep 17 00:00:00 2001
From: HONG Yifan <elsk@google.com>
Date: Fri, 18 Jul 2025 22:58:54 +0000
Subject: [PATCH 1/5] Use our local_repository.

https://github.com/bazelbuild/bazel/issues/26578
---
MODULE.bazel | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/MODULE.bazel b/MODULE.bazel
index 191f4bd..c6432e1 100644
--- a/MODULE.bazel
+++ b/MODULE.bazel
@@ -14,8 +14,8 @@ bazel_dep(name = "openssl", version = "3.3.1.bcr.1")
 bazel_dep(name = "protobuf", version = "33.4")
 bazel_dep(name = "gflags", version = "2.2.2.bcr.1")
 
-local_repository = use_repo_rule("@bazel_tools//tools/build_defs/repo:local.bzl", "local_repository")
-new_local_repository = use_repo_rule("@bazel_tools//tools/build_defs/repo:local.bzl", "new_local_repository")
+local_repository = use_repo_rule("@@//cuttlefish/bazel:local.bzl", "local_repository")
+new_local_repository = use_repo_rule("@@//cuttlefish/bazel:local.bzl", "new_local_repository")
 
 new_local_repository(
     name = "fmtlib",
@@ -30,7 +30,7 @@ new_local_repository(
     build_file = "//:BUILD.pdl",
 )
 
-crate = use_extension("@rules_rust//crate_universe:extensions.bzl", "crate")
+crate = use_extension("@rules_rust//crate_universe:extensions.bzl", "crate", isolate = True)
 
 crate.spec(package = "bytes", version = "1.0.1")
 crate.spec(package = "num-bigint", version = "0.4.3")
-- 
